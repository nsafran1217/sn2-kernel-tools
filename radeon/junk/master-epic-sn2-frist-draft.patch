diff --git a/drivers/gpu/drm/ttm/ttm_module.c b/drivers/gpu/drm/ttm/ttm_module.c
index aa137ea..65e60c0 100644
--- a/drivers/gpu/drm/ttm/ttm_module.c
+++ b/drivers/gpu/drm/ttm/ttm_module.c
@@ -61,6 +61,14 @@
  */
 pgprot_t ttm_prot_from_caching(enum ttm_caching caching, pgprot_t tmp)
 {
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: ALL GPU-accessible memory must use UC page protection.
+	 * WB creates Modified cache lines → RDEXC interventions → MCA.
+	 * This catches ttm_kmap_iter (used by ttm_move_memcpy) which
+	 * calls ttm_prot_from_caching directly, bypassing ttm_io_prot.
+	 * See SGI Altix Porting Guide (007-4520-007) pages 89-90. */
+	return pgprot_noncached(tmp);
+#endif
 	/* Cached mappings need no adjustment */
 	if (caching == ttm_cached)
 		return tmp;
