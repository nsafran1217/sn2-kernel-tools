 	 * For TIOCP use the Device(x) Write Request Buffer Flush Bridge
@@ -336,20 +348,23 @@ void sn_dma_flush(unsigned long addr)
 			pcireg_wrb_flush_get(common->sfdl_pcibus_info,
 					     (common->sfdl_slot - 1));
 		}
-	} else {
-		spin_lock_irqsave(&p->sfdl_flush_lock, flags);
-		*common->sfdl_flush_addr = 0;
+		return;
+	}
 
-		/* force an interrupt. */
-		*(volatile u32 *)(common->sfdl_force_int_addr) = 1;
+	/* PIC flush — also reached via fallback for devices behind PPBs */
+do_flush:
+	spin_lock_irqsave(&p->sfdl_flush_lock, flags);
+	*common->sfdl_flush_addr = 0;
 
-		/* wait for the interrupt to come back. */
-		while (*(common->sfdl_flush_addr) != 0x10f)
-			cpu_relax();
+	/* force an interrupt. */
+	*(volatile u32 *)(common->sfdl_force_int_addr) = 1;
 
-		/* okay, everything is synched up. */
-		spin_unlock_irqrestore(&p->sfdl_flush_lock, flags);
-	}
+	/* wait for the interrupt to come back. */
+	while (*(common->sfdl_flush_addr) != 0x10f)
+		cpu_relax();
+
+	/* okay, everything is synched up. */
+	spin_unlock_irqrestore(&p->sfdl_flush_lock, flags);
 	return;
 }
 
diff --git a/drivers/gpu/drm/radeon/radeon_device.c b/drivers/gpu/drm/radeon/radeon_device.c
index 5d523d5..576f4c0 100644
--- a/drivers/gpu/drm/radeon/radeon_device.c
+++ b/drivers/gpu/drm/radeon/radeon_device.c
@@ -1377,6 +1377,14 @@ int radeon_device_init(struct radeon_device *rdev,
 	rdev->pdev->msi_addr_mask = DMA_BIT_MASK(dma_bits);
 	rdev->need_swiotlb = drm_need_swiotlb(dma_bits);
 
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: drm_need_swiotlb() false positive from NASID-encoded phys addrs.
+	 * With need_swiotlb=true, TTM uses dma_alloc_coherent which creates
+	 * barrier ATEs (PCI32_ATE_BAR). The PIC has only 1024 ATEs (16MB),
+	 * quickly exhausted under GPU load. Force streaming DMA (direct32). */
+	rdev->need_swiotlb = false;
+#endif
+
 	/* Registers mapping */
 	/* TODO: block userspace mapping of io register */
 	spin_lock_init(&rdev->mmio_idx_lock);
diff --git a/drivers/gpu/drm/radeon/radeon_fence.c b/drivers/gpu/drm/radeon/radeon_fence.c
index 02a40e4..bf2455b 100644
--- a/drivers/gpu/drm/radeon/radeon_fence.c
+++ b/drivers/gpu/drm/radeon/radeon_fence.c
@@ -290,6 +290,16 @@ static void radeon_fence_check_lockup(struct work_struct *work)
 		spin_unlock_irqrestore(&rdev->irq.lock, irqflags);
 	}
 
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: Flush PIC posted DMA write buffers during fence polling.
+	 * With WB enabled, fence checks read system memory directly — no
+	 * PIO reads happen, so sn_dma_flush() is never triggered. Without
+	 * periodic flushing, GPU DMA writes may remain buffered in the PIC.
+	 * RREG32 triggers readl() → sn_dma_flush() on SN2 platform. */
+	if (ring == 0)
+		(void)RREG32(RADEON_SCRATCH_REG0);
+#endif
+
 	if (radeon_fence_activity(rdev, ring))
 		wake_up_all(&rdev->fence_queue);
 
