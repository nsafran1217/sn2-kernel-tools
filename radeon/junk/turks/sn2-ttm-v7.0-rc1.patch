diff --git a/drivers/gpu/drm/ttm/ttm_bo_util.c b/drivers/gpu/drm/ttm/ttm_bo_util.c
index f83b7d5..5b4842b 100644
--- a/drivers/gpu/drm/ttm/ttm_bo_util.c
+++ b/drivers/gpu/drm/ttm/ttm_bo_util.c
@@ -307,6 +307,18 @@ pgprot_t ttm_io_prot(struct ttm_buffer_object *bo, struct ttm_resource *res,
 		caching = res->bus.caching;
 	}
 
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: Device memory (VRAM, doorbell, MMIO) is accessed via PIO.
+	 * Write-combining (_PAGE_MA_WC) causes CPU write buffers to never
+	 * flush through the SN2 PIO path (CPU→SHub→PIC→device).
+	 * Write-back (_PAGE_MA_WB) risks stale cache reads of device memory.
+	 * Force uncacheable (_PAGE_MA_UC) for all device memory mappings.
+	 * System memory (GTT, use_tt=true) is unaffected.
+	 * See SGI Altix Porting Guide (007-4520-007) page 67. */
+	if (!man->use_tt)
+		return pgprot_noncached(tmp);
+#endif
+
 	return ttm_prot_from_caching(caching, tmp);
 }
 EXPORT_SYMBOL(ttm_io_prot);
