index b67bb4c..87ae2a4 100644
--- a/arch/ia64/sn/pci/pcibr/pcibr_ate.c
+++ b/arch/ia64/sn/pci/pcibr/pcibr_ate.c
@@ -175,3 +175,86 @@ void pcibr_ate_free(struct pcibus_info *pcibus_info, int index)
 	free_ate_resource(&pcibus_info->pbi_int_ate_resource, index);
 	spin_unlock_irqrestore(&pcibus_info->pbi_lock, flags);
 }
+
+/**
+ * pcibr_ate_force - Write an ATE entry at a specific index
+ *
+ * @pcibus_info: PIC bus info structure
+ * @index: exact ATE index to write (must match GPU GART page index)
+ * @phys_addr: physical address of the page to map
+ *
+ * Used by GPU drivers on SN2 where the GPU's rendering/display engines
+ * bypass the GPU's own GART table and issue PCIe transactions using the
+ * raw GPU MC address (PCI32_MAPPED_BASE + index * IOPGSIZE).  The PIC
+ * must have an ATE at that exact index to translate the transaction to
+ * the correct physical page.
+ *
+ * Unlike pcibr_ate_alloc(), this function writes at a caller-specified
+ * index rather than the next free index, ensuring ATE index == GART page
+ * index so both GART-using and GART-bypassing GPU engines see the same
+ * translation.
+ *
+ * Returns 0 on success, -EINVAL if index is out of range.
+ */
+int pcibr_ate_force(struct pcibus_info *pcibus_info, int index,
+		    unsigned long phys_addr)
+{
+	u64 xio_addr;
+	u64 ate;
+	unsigned long flags;
+
+	if (index < 0 || index >= pcibus_info->pbi_int_ate_size)
+		return -EINVAL;
+
+	/* Convert physical address to XIO (NUMAlink fabric) address */
+	xio_addr = IS_PIC_SOFT(pcibus_info) ? PHYS_TO_DMA(phys_addr) :
+					      PHYS_TO_TIODMA(phys_addr);
+
+	/*
+	 * Build ATE value: XIO base address (page-aligned) | flags.
+	 * Use PCI32_ATE_PREF (prefetch) not PCI32_ATE_BAR (barrier) —
+	 * BAR generates WrReqWithResp xtalk packets which crash the PIC
+	 * for devices behind secondary buses (e.g. GPU behind PLX bridge).
+	 */
+	ate = PCI32_ATE_V | PCI32_ATE_PREF | (xio_addr & ~IOPGOFF(~0ULL));
+
+	/* PIC requires target node ID in bits 15:8 of the ATE */
+	if (IS_PIC_SOFT(pcibus_info))
+		ate |= (pcibus_info->pbi_hub_xid << PIC_ATE_TARGETID_SHFT);
+
+	/* Mark in the software allocation bitmap to prevent double-use */
+	spin_lock_irqsave(&pcibus_info->pbi_lock, flags);
+	pcibus_info->pbi_int_ate_resource.ate[index] = 1;
+	spin_unlock_irqrestore(&pcibus_info->pbi_lock, flags);
+
+	/* Write the ATE to hardware and flush */
+	ate_write(pcibus_info, index, 1, ate);
+
+	return 0;
+}
+EXPORT_SYMBOL(pcibr_ate_force);
+
+/**
+ * pcibr_ate_force_free - Release an ATE written by pcibr_ate_force
+ *
+ * @pcibus_info: PIC bus info structure
+ * @index: ATE index to release
+ */
+void pcibr_ate_force_free(struct pcibus_info *pcibus_info, int index)
+{
+	unsigned long flags;
+
+	if (index < 0 || index >= pcibus_info->pbi_int_ate_size)
+		return;
+
+	/* Optionally invalidate the ATE in hardware */
+	if (pcibr_invalidate_ate) {
+		u64 ate = *pcibr_ate_addr(pcibus_info, index);
+		ate_write(pcibus_info, index, 1, ate & ~PCI32_ATE_V);
+	}
+
+	spin_lock_irqsave(&pcibus_info->pbi_lock, flags);
+	pcibus_info->pbi_int_ate_resource.ate[index] = 0;
+	spin_unlock_irqrestore(&pcibus_info->pbi_lock, flags);
+}
+EXPORT_SYMBOL(pcibr_ate_force_free);
