+ * PCI Bridge Error interrupt handler.  Gets invoked whenever a PCI
  * bridge sends an error interrupt.
  */
+
+/* Global PIO freeze flag - set on bridge error to stop all device PIO */
+atomic_t pcibr_pio_frozen = ATOMIC_INIT(0);
+EXPORT_SYMBOL(pcibr_pio_frozen);
+
+/* Hook for GPU driver to dump PIO trace on bridge errors */
+void (*pcibr_error_dump_hook)(const char *reason);
+EXPORT_SYMBOL(pcibr_error_dump_hook);
+
+static atomic_t pcibr_error_count = ATOMIC_INIT(0);
+
 static irqreturn_t
 pcibr_error_intr_handler(int irq, void *arg)
 {
 	struct pcibus_info *soft = arg;
+	int ret;
+	int count;
+
+	ret = sal_pcibr_error_interrupt(soft);
+	count = atomic_inc_return(&pcibr_error_count);
+
+	if (ret < 0) {
+		/* SAL says fatal — freeze all PIO to prevent MCA cascade */
+		atomic_set(&pcibr_pio_frozen, 1);
+		pr_err("pcibr_error_intr_handler(): Fatal Bridge Error #%d (SAL=%d) - PIO FROZEN\n",
+		       count, ret);
+	} else {
+		/* Non-fatal — log and dump but do NOT freeze PIO.
+		 * Freezing on non-fatal errors (e.g. bit 30 PMU Access Fault)
+		 * blocks all GPU register writes, preventing clean teardown
+		 * and causing ATOMBIOS timeout loops. */
+		pr_warn("pcibr_error_intr_handler(): Bridge Error #%d (non-fatal, SAL=%d)\n",
+			count, ret);
+	}
+
+	/* Dump GPU PIO trace if a driver registered a hook */
+	if (pcibr_error_dump_hook)
+		pcibr_error_dump_hook("PIC_BRIDGE_ERROR");
 
-	if (sal_pcibr_error_interrupt(soft) < 0)
-		panic("pcibr_error_intr_handler(): Fatal Bridge Error");
+	dump_stack();
 
 	return IRQ_HANDLED;
 }
