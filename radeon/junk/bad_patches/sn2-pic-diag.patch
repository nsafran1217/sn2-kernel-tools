+/**
+ * sn2_pic_check_errors - Read PIC error registers and log any errors
+ * @pdev: PCI device on this PIC
+ *
+ * Reads BUS1_INT_STATUS and if any error bits (bits 45:9) are set,
+ * dumps all PIC error capture registers. This catches PCI bus errors
+ * BEFORE they escalate to an MCA.
+ *
+ * Returns the raw INT_STATUS value (0 = no errors).
+ *
+ * Register map from pic_01_mmrs.pm (SGI PIC hardware register database):
+ *   p_int_status       (0x100) = BUS1_INT_STATUS
+ *   p_pci_err_upper    (0x0D0) = BUS1_PCI_ERR_UPPER_ADDR
+ *   p_pci_err_lower    (0x0D8) = BUS1_PCI_ERR_LOWER_ADDR
+ *   p_pcix_bus_err_addr(0x600) = BUS1_PCI_X_ERR_ADDR
+ *   p_pcix_bus_err_attr(0x608) = BUS1_PCI_X_ERR_ATTR
+ *   p_pcix_dma_req_err_attr(0x628) = BUS1_PCI_X_DMA_ERR_ATTR
+ *   p_pcix_dma_req_err_addr(0x630) = BUS1_PCI_X_DMA_ERR_ADDR
+ *   p_pcix_timeout     (0x638) = BUS1_PCI_X_READ_REQ_TOUT
+ *   p_resp_status      (0x290) = BUS1_RR_BUFF_STATUS
+ */
+// [DEBUG INSTRUMENTATION]
+u64 sn2_pic_check_errors(struct pci_dev *pdev)
+{
+	struct pcidev_info *pcidev_info = SN_PCIDEV_INFO(pdev);
+	struct pcibus_info *pcibus_info;
+	struct pic __iomem *p;
+	u64 int_status, err_upper, err_lower;
+	u64 pcix_err_addr, pcix_err_attr, pcix_err_data;
+	u64 dma_err_addr, dma_err_attr;
+	u64 pcix_timeout, resp_status;
+	u64 err_int_view, mult_int;
+	static int error_dump_count = 0;
+
+	if (!pcidev_info || !pcidev_info->pdi_host_pcidev_info)
+		return 0;
+
+	pcibus_info = (struct pcibus_info *)
+		pcidev_info->pdi_host_pcidev_info->pdi_pcibus_info;
+	if (!pcibus_info || !IS_PIC_SOFT(pcibus_info))
+		return 0;
+
+	p = (struct pic __iomem *)pcibus_info->pbi_buscommon.bs_base;
+
+	/* Read INT_STATUS — use relaxed read to avoid triggering sn_dma_flush
+	 * recursion (we're often called from the fence check path) */
+	int_status = __sn_readq_relaxed(&p->p_int_status);
+
+	/* Check for error bits: everything above bit 8 except reserved.
+	 * Bits 7:0 are normal device interrupt state (not errors).
+	 * Error mask: bits 45:9 */
+	#define PIC_INT_STATUS_ERR_MASK 0x00003FFFFFFFFE00ULL
+
+	if (!(int_status & PIC_INT_STATUS_ERR_MASK))
+		return int_status;  /* No errors — return quickly */
+
+	/* ERROR DETECTED — dump everything.
+	 * Limit to first 20 dumps to avoid flooding dmesg. */
+	if (error_dump_count >= 20)
+		return int_status;
+	error_dump_count++;
+
+	/* Read all error capture registers */
+	err_upper      = __sn_readq_relaxed(&p->p_pci_err_upper);
+	err_lower      = __sn_readq_relaxed(&p->p_pci_err_lower);
+	pcix_err_addr  = __sn_readq_relaxed(&p->p_pcix_bus_err_addr);
+	pcix_err_attr  = __sn_readq_relaxed(&p->p_pcix_bus_err_attr);
+	pcix_err_data  = __sn_readq_relaxed(&p->p_pcix_bus_err_data);
+	dma_err_attr   = __sn_readq_relaxed(&p->p_pcix_dma_req_err_attr);
+	dma_err_addr   = __sn_readq_relaxed(&p->p_pcix_dma_req_err_addr);
+	pcix_timeout   = __sn_readq_relaxed(&p->p_pcix_timeout);
+	resp_status    = __sn_readq_relaxed(&p->p_resp_status);
+	err_int_view   = __sn_readq_relaxed(&p->p_err_int_view);
+	mult_int       = __sn_readq_relaxed(&p->p_mult_int);
+
+	printk(KERN_CRIT "[SN2-PIC-ERR] ========== PIC ERROR #%d ==========\n",
+	       error_dump_count);
+	printk(KERN_CRIT "[SN2-PIC-ERR] INT_STATUS=0x%016llx\n", int_status);
+
+	/* Decode known error bits */
+	if (int_status & (1ULL << 39))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit39: PCI_X_REQ_TOUT — "
+		       "Read request timeout (GPU not responding)\n");
+	if (int_status & (1ULL << 34))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit34: PCI_X_MTOUT — "
+		       "Master timeout (PIO stuck, device no devsel)\n");
+	if (int_status & (1ULL << 30))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit30: PMU_PAGE_FAULT — "
+		       "Invalid PCI page access (ATE miss)\n");
+	if (int_status & (1ULL << 29))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit29: UNEXPECTED_RESP — "
+		       "Unexpected response from device\n");
+	if (int_status & (1ULL << 26))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit26: RESP_XTALK_ERROR — "
+		       "Response had error bit or invalid sideband\n");
+	if (int_status & (1ULL << 24))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit24: INVALID_ACCESS — "
+		       "Invalid address/access type\n");
+	if (int_status & (1ULL << 9))
+		printk(KERN_CRIT "[SN2-PIC-ERR]   bit9: XREAD_REQ_TOUT — "
+		       "PCI to Crosstalk read request timeout\n");
+
+	printk(KERN_CRIT "[SN2-PIC-ERR] ERR_INT_VIEW=0x%016llx "
+	       "MULT_INT=0x%016llx\n", err_int_view, mult_int);
+	printk(KERN_CRIT "[SN2-PIC-ERR] PCI_ERR_ADDR=0x%016llx_%016llx\n",
+	       err_upper, err_lower);
+	printk(KERN_CRIT "[SN2-PIC-ERR] PCIX_ERR: addr=0x%016llx "
+	       "attr=0x%016llx data=0x%016llx\n",
+	       pcix_err_addr, pcix_err_attr, pcix_err_data);
+	printk(KERN_CRIT "[SN2-PIC-ERR] DMA_ERR: addr=0x%016llx "
+	       "attr=0x%016llx\n", dma_err_addr, dma_err_attr);
+	printk(KERN_CRIT "[SN2-PIC-ERR] PCIX_TIMEOUT=0x%016llx "
+	       "RR_BUFF_STATUS=0x%016llx\n", pcix_timeout, resp_status);
+	printk(KERN_CRIT "[SN2-PIC-ERR] ==============================\n");
+
+	return int_status;
+}
+EXPORT_SYMBOL(sn2_pic_check_errors);
+
+/**
+ * sn2_shub_state_snapshot - Read SHub II + PI state for GPU MCA diagnosis
+ * @nasid: NASID of the SHub to read (0 for local node)
+ *
+ * Reads and logs:
+ * 1. II chiplet: WSTAT, IXSS, IPRBF (widget 15 PRB), IIEPH1/2
+ * 2. PI: FIRST_ERROR, ERROR_SUMMARY, ERROR_DETAIL_1/2
+ * 3. PI CAM: WRB states (32 entries) — the key diagnostic
+ *
+ * Call periodically from fence check during Minecraft to catch
+ * the transition from normal to GOOFY WRB state.
+ *
+ * [Evidence: ALL 32 WRBs go GOOFY during heavy 3D — errdmp]
+ * [Evidence: FSB_PROTO_ERR set during Minecraft before MCA]
+ */
+// [DEBUG INSTRUMENTATION]
+void sn2_shub_state_snapshot(int nasid, int force)
+{
+	u64 ii_wstat, ii_ixss, ii_iprbf, ii_iieph1, ii_iieph2;
+	u64 pi_first_err, pi_err_summary, pi_err_detail1, pi_err_detail2;
+	int i, wrb_free, wrb_snoop, wrb_wack, wrb_other;
+	u64 wrb_states[32];
+	u64 wrb_addrs[32];
+	static u64 last_pi_err_summary = 0;
+
+	/* 1. Read II chiplet registers */
+	ii_wstat  = REMOTE_HUB_L(nasid, IIO_WSTAT);
+	ii_ixss   = REMOTE_HUB_L(nasid, IIO_IXSS);
+	ii_iprbf  = REMOTE_HUB_L(nasid, IIO_IPRBF);  /* widget F = 15 = PIC */
+	ii_iieph1 = REMOTE_HUB_L(nasid, IIO_IIEPH1);
+	ii_iieph2 = REMOTE_HUB_L(nasid, IIO_IIEPH2);
+
+	/* 2. Read PI error registers (SHub1 addresses) */
+	pi_first_err   = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060780));
+	pi_err_summary = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060680));
+	pi_err_detail1 = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060500));
+	pi_err_detail2 = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060580));
+
+	/* 3. Read PI CAM — all 32 WRB entries
+	 * CAM_CONTROL index: [6:5]=type (1=WRB), [4:0]=entry
+	 * After writing control, read address and state. */
+	wrb_free = wrb_snoop = wrb_wack = wrb_other = 0;
+	for (i = 0; i < 32; i++) {
+		u64 cam_idx = (1 << 5) | i;  /* type=1 (WRB), entry=i */
+		u64 state_raw, addr_raw;
+		int state;
+
+		HUB_L((u64 *)LOCAL_MMR_ADDR(SH1_PI_CAM_CONTROL));  /* sync */
+		*(volatile u64 *)LOCAL_MMR_ADDR(SH1_PI_CAM_CONTROL) = cam_idx;
+		/* Read back to ensure write completed */
+		(void)HUB_L((u64 *)LOCAL_MMR_ADDR(SH1_PI_CAM_CONTROL));
+
+		addr_raw  = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060100));
+		state_raw = HUB_L((u64 *)LOCAL_MMR_ADDR(0x0000000120060200));
+		state = state_raw & 0xf;
+
+		wrb_states[i] = state_raw;
+		wrb_addrs[i] = addr_raw;
+
+		if (state == 0) wrb_free++;
+		else if (state == 12 || state == 13) wrb_snoop++;
+		else if (state == 8) wrb_wack++;
+		else wrb_other++;
+	}
+
+	/* Only log if something interesting is happening:
+	 * - PI error bits changed
+	 * - WRBs not all FREE
+	 * - II CRB in error
+	 * - II_WSTAT errors (NOT ii_ixss — it's 0x34 from boot, constant) */
+	{
+		int ii_crb_errors = 0;
+		int ii_crb_active = 0;
+		u64 crb_a[15], crb_e[15];
+
+		/* Read all 15 II CRBs — these track PIC↔SHub transactions */
+		for (i = 0; i < IIO_NUM_CRBS; i++) {
+			crb_a[i] = REMOTE_HUB_L(nasid, IIO_ICRB_A(i));
+			crb_e[i] = REMOTE_HUB_L(nasid, IIO_ICRB_E(i));
+			if (crb_a[i] != 0) ii_crb_active++;
+			/* _B register bit 0 (mark) indicates error */
+			{
+				u64 crb_b = REMOTE_HUB_L(nasid, IIO_ICRB_B(i));
+				if (crb_b & 1) ii_crb_errors++;
+			}
+		}
+
+		if (force ||
+		    pi_err_summary != last_pi_err_summary ||
+		    wrb_free < 32 ||
+		    ii_crb_errors > 0 ||
+		    (ii_wstat & 0x130)) {
+
+			last_pi_err_summary = pi_err_summary;
+
+			printk(KERN_WARNING "[SN2-SHUB] === SHub State Snapshot ===\n");
+
+			/* II state */
+			printk(KERN_WARNING "[SN2-SHUB] II_WSTAT=0x%016llx "
+			       "II_IXSS=0x%016llx II_IPRBF=0x%016llx\n",
+			       ii_wstat, ii_ixss, ii_iprbf);
+			if (ii_iieph1 || ii_iieph2)
+				printk(KERN_WARNING "[SN2-SHUB] II_IIEPH1="
+				       "0x%016llx II_IIEPH2=0x%016llx\n",
+				       ii_iieph1, ii_iieph2);
+
+			/* PI error state */
+			printk(KERN_WARNING "[SN2-SHUB] PI_FIRST_ERR=0x%016llx "
+			       "PI_ERR_SUMMARY=0x%016llx\n",
+			       pi_first_err, pi_err_summary);
+			if (pi_err_detail1 || pi_err_detail2)
+				printk(KERN_WARNING "[SN2-SHUB] PI_DETAIL1="
+				       "0x%016llx DETAIL2=0x%016llx\n",
+				       pi_err_detail1, pi_err_detail2);
+
+			/* WRB summary */
+			printk(KERN_WARNING "[SN2-SHUB] WRB: free=%d snoop=%d "
+			       "wack=%d other=%d\n",
+			       wrb_free, wrb_snoop, wrb_wack, wrb_other);
+
+			/* Print non-FREE WRBs */
+			for (i = 0; i < 32; i++) {
+				int st = wrb_states[i] & 0xf;
+				if (st != 0) {
+					const char *sn;
+					switch (st) {
+					case 8: sn = "WACK"; break;
+					case 12: sn = "SNOOP"; break;
+					case 13: sn = "SNPP"; break;
+					case 14: sn = "SNPRY"; break;
+					case 15: sn = "SNPRR"; break;
+					default: sn = "UNK"; break;
+					}
+					printk(KERN_WARNING "[SN2-SHUB]   WRB[%d] "
+					       "state=%d(%s) addr=0x%016llx\n",
+					       i, st, sn, wrb_addrs[i]);
+				}
+			}
+
+			/* II CRBs — active/error */
+			printk(KERN_WARNING "[SN2-SHUB] II_CRB: active=%d "
+			       "errors=%d\n", ii_crb_active, ii_crb_errors);
+			for (i = 0; i < IIO_NUM_CRBS; i++) {
+				if (crb_a[i] != 0 || (crb_e[i] & 0xffff)) {
+					u64 crb_b = REMOTE_HUB_L(nasid,
+						IIO_ICRB_B(i));
+					u64 crb_c = REMOTE_HUB_L(nasid,
+						IIO_ICRB_C(i));
+					printk(KERN_WARNING "[SN2-SHUB]   "
+					       "IICRB[%d] A=0x%016llx "
+					       "B=0x%016llx C=0x%016llx "
+					       "E=0x%016llx\n",
+					       i, crb_a[i], crb_b,
+					       crb_c, crb_e[i]);
+				}
+			}
+
+			printk(KERN_WARNING "[SN2-SHUB] === End Snapshot ===\n");
+		}
+	}
+}
+EXPORT_SYMBOL(sn2_shub_state_snapshot);
