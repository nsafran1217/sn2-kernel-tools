+		 * Track GPU command completion rate via fence sequence.
+		 * Each fence advance = one GPU command completed = at least
+		 * one DMA write (fence value) to system memory.
+		 * High rate during Minecraft tells us DMA pressure. */
+		{
+			u64 cur_seq = (u64)atomic64_read(
+				&rdev->fence_drv[0].last_seq);
+			if (cur_seq != last_fence_seq) {
+				fence_advance_count +=
+					(int)(cur_seq - last_fence_seq);
+				last_fence_seq = cur_seq;
+			}
+		}
+
+		/* === #3: PIO Pending Count (corrected for SHub1) === */
+		pio_max = sn2_pio_write_status(pio_counts, pio_deadlock, 4);
+		if (pio_max > pio_max_seen)
+			pio_max_seen = pio_max;
+		if (pio_max > 50 && pio_high_count < 200) {
+			pio_high_count++;
+			printk(KERN_WARNING "[SN2-PIO-PENDING] #%d: "
+			       "cpu0=%llu cpu1=%llu max_pending=%d "
+			       "max_ever=%d deadlock=[%d,%d]\n",
+			       pio_high_count,
+			       pio_counts[0], pio_counts[1],
+			       pio_max, pio_max_seen,
+			       pio_deadlock[0], pio_deadlock[1]);
+		}
+		if (pio_max > 60)
+			printk(KERN_CRIT "[SN2-PIO-CRITICAL] pending=%d "
+			       "cpu0=%llu cpu1=%llu\n",
+			       pio_max, pio_counts[0], pio_counts[1]);
+		if (pio_deadlock[0] || pio_deadlock[1])
+			printk(KERN_CRIT "[SN2-PIO-DEADLOCK] cpu0=%d cpu1=%d\n",
+			       pio_deadlock[0], pio_deadlock[1]);
+
+		/* SN2: Direct mmiowb + sn_dma_flush (fglrx pattern)
+		 * Instead of relying on RREG32 → readl → sn_dma_flush,
+		 * call both barriers explicitly with GPU MMIO address. */
+		__sn_mmiowb();
+		sn_dma_flush((unsigned long)rdev->rmmio);
+
+		/* PIC error check */
+		{
+			u64 pic_err = sn2_pic_check_errors(rdev->pdev);
+			if ((check_count % 20) == 1)
+				printk(KERN_INFO "[SN2-PIC-STATUS] "
+				       "INT_STATUS=0x%016llx\n", pic_err);
+		}
+
+		/* PIC WRB flush for all slots */
+		sn2_pic_read_wrb_all(rdev->pdev, wrb_vals);
+
+		/* Periodic summary (every 20 checks = ~10 sec) */
+		if ((check_count % 20) == 1) {
+			int rate = fence_advance_count -
+				   fence_advance_last_report;
+			fence_advance_last_report = fence_advance_count;
+			printk(KERN_INFO "[SN2-WRB] wrb[0]=0x%llx "
+			       "wrb[1]=0x%llx wrb[2]=0x%llx wrb[3]=0x%llx\n",
+			       wrb_vals[0], wrb_vals[1],
+			       wrb_vals[2], wrb_vals[3]);
+			printk(KERN_INFO "[SN2-SUMMARY] pio_max_ever=%d "
+			       "pio_events=%d fence_total=%d "
+			       "fence_rate=%d/10s\n",
+			       pio_max_seen, pio_high_count,
+			       fence_advance_count, rate);
+			{
+				extern int sn2_flush_fallback_count;
+				extern int sn2_flush_total_count;
+				printk(KERN_INFO "[SN2-FLUSH-STATS] "
+				       "total=%d fallback=%d bar_match=%d\n",
+				       sn2_flush_total_count,
+				       sn2_flush_fallback_count,
+				       sn2_flush_total_count -
+				       sn2_flush_fallback_count);
+			}
+		}
 	}
 #endif
 
diff --git a/drivers/gpu/drm/radeon/radeon_ring.c b/drivers/gpu/drm/radeon/radeon_ring.c
index 581ae20..316092f 100644
--- a/drivers/gpu/drm/radeon/radeon_ring.c
+++ b/drivers/gpu/drm/radeon/radeon_ring.c
@@ -201,6 +201,30 @@ void radeon_ring_unlock_commit(struct radeon_device *rdev, struct radeon_ring *r
 			       bool hdp_flush)
 {
 	radeon_ring_commit(rdev, ring, hdp_flush);
+#ifdef CONFIG_IA64_SGI_SN2
+	/* [SN2 FLOW CONTROL] Direct mmiowb + dma_flush after ring commit.
+	 *
+	 * fglrx (only working GPU driver on SN2) calls:
+	 *   __sn_mmiowb() after EVERY PIO write  (drain PIO write buffers)
+	 *   sn_dma_flush() after EVERY PIO read   (flush device DMA writes)
+	 *
+	 * radeon_ring_commit → cayman_gfx_set_wptr does:
+	 *   WREG32(CP_RB0_WPTR, wptr) → writel (NO mmiowb!)
+	 *   RREG32(CP_RB0_WPTR)       → readl  (calls sn_dma_flush)
+	 *
+	 * But the readl-triggered sn_dma_flush may not work correctly
+	 * for the GPU — its BARs may not be in the PROM's flush list.
+	 * Call both barriers directly with the GPU's known MMIO address.
+	 */
+	{
+		extern void __sn_mmiowb(void);
+		extern void sn_dma_flush(unsigned long);
+		/* 1. Drain CPU→GPU PIO writes (mmiowb) */
+		__sn_mmiowb();
+		/* 2. Flush GPU→memory DMA writes (force interrupt on PIC) */
+		sn_dma_flush((unsigned long)rdev->rmmio);
+	}
+#endif
 	mutex_unlock(&rdev->ring_lock);
 }
 
