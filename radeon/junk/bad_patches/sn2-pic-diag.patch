+/**
+ * sn2_pic_wrb_flush_slot - Flush WRBs for a specific PIC device slot
+ * @pdev: any PCI device whose host is on this PIC
+ * @slot: PIC device slot (0-3), where slot = PCI_SLOT(host_devfn) - 1
+ *
+ * Reads the per-slot WRB flush register on PIC. This drains write
+ * request buffers for that slot at the PIC level (but does NOT
+ * guarantee data entered the SHub coherence domain — that requires
+ * the forced-interrupt mechanism).
+ *
+ * Returns the value read (should be 0 if flush completed).
+ */
+// [DEBUG INSTRUMENTATION]
+u64 sn2_pic_wrb_flush_slot(struct pci_dev *pdev, int slot)
+{
+	struct pcidev_info *pcidev_info = SN_PCIDEV_INFO(pdev);
+	struct pcibus_info *pcibus_info;
+
+	if (!pcidev_info || !pcidev_info->pdi_host_pcidev_info)
+		return ~0ULL;
+
+	pcibus_info = (struct pcibus_info *)
+		pcidev_info->pdi_host_pcidev_info->pdi_pcibus_info;
+	if (!pcibus_info || !IS_PIC_SOFT(pcibus_info))
+		return ~0ULL;
+
+	if (slot < 0 || slot > 3)
+		return ~0ULL;
+
+	return pcireg_wrb_flush_get(pcibus_info, slot);
+}
+EXPORT_SYMBOL(sn2_pic_wrb_flush_slot);
+
+/**
+ * sn2_pic_tflush - Execute PIC Target Flush (global)
+ * @pdev: any PCI device whose host is on this PIC
+ *
+ * Reads p_wid_tflush which forces all pending PIC transactions to
+ * complete. This is a global flush, not per-slot.
+ *
+ * Returns 0 on success, non-zero if flush register returned unexpected value.
+ */
+// [DEBUG INSTRUMENTATION]
+int sn2_pic_tflush(struct pci_dev *pdev)
+{
+	struct pcidev_info *pcidev_info = SN_PCIDEV_INFO(pdev);
+	struct pcibus_info *pcibus_info;
+
+	if (!pcidev_info || !pcidev_info->pdi_host_pcidev_info)
+		return -1;
+
+	pcibus_info = (struct pcibus_info *)
+		pcidev_info->pdi_host_pcidev_info->pdi_pcibus_info;
+	if (!pcibus_info)
+		return -1;
+
+	/* pcireg_tflush_get panics if non-zero, so be careful */
+	return (int)pcireg_tflush_get(pcibus_info);
+}
+EXPORT_SYMBOL(sn2_pic_tflush);
