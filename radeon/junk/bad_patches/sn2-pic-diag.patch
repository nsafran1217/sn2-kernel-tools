 	.unmap_phys		= sn_dma_unmap_phys,
 	.map_sg			= sn_dma_map_sg,
 	.unmap_sg		= sn_dma_unmap_sg,
+	.sync_single_for_device	= sn_dma_sync_single_for_device,
+	.sync_sg_for_device	= sn_dma_sync_sg_for_device,
 	.dma_supported		= sn_dma_supported,
