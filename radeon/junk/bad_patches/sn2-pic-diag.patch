+/* =====================================================================
+ *    [DEBUG INSTRUMENTATION] PIC Bridge Diagnostics for GPU Debugging
+ *
+ *    These functions allow the GPU driver to inspect and interact with
+ *    the PIC bridge hardware directly, which is needed because devices
+ *    behind PCI-PCI bridges (PPBs) are invisible to the standard
+ *    sn_dma_flush mechanism.
+ * =====================================================================
+ */
+
+/**
+ * sn2_pic_bridge_dump - Dump PIC bridge state for a PCI device
+ * @pdev: any PCI device on this PIC bus (e.g., the GPU or PLX bridge)
+ *
+ * Reads and logs PIC registers: RRB map, WRB status, direct map,
+ * flush list entries, and device registers. Call at driver probe time.
+ */
+// [DEBUG INSTRUMENTATION]
+void sn2_pic_bridge_dump(struct pci_dev *pdev)
+{
+	struct pcidev_info *pcidev_info = SN_PCIDEV_INFO(pdev);
+	struct pcibus_info *pcibus_info;
+	struct pic __iomem *pic_regs;
+	u64 rrb_even, rrb_odd, dir_map, int_enable, int_status;
+	u64 wrb[4], device_reg[4];
+	int i, j;
+	nasid_t nasid;
+	int cnode, wid_num;
+	struct hubdev_info *hubinfo;
+	struct sn_flush_device_kernel *fdk;
+	u8 host_slot;
+
+	if (!pcidev_info || !pcidev_info->pdi_host_pcidev_info)
+		return;
+
+	pcibus_info = (struct pcibus_info *)
+		pcidev_info->pdi_host_pcidev_info->pdi_pcibus_info;
+	if (!pcibus_info || !IS_PIC_SOFT(pcibus_info))
+		return;
+
+	pic_regs = (struct pic __iomem *)pcibus_info->pbi_buscommon.bs_base;
+	host_slot = PCI_SLOT(pcidev_info->pdi_host_pcidev_info->
+				pdi_linux_pcidev->devfn);
+
+	printk(KERN_INFO "[SN2-PIC-DUMP] === PIC Bridge State for %s ===\n",
+	       pci_name(pdev));
+	printk(KERN_INFO "[SN2-PIC-DUMP] PIC base=0x%lx bridge_type=%d "
+	       "bridge_mode=%d\n",
+	       pcibus_info->pbi_buscommon.bs_base,
+	       pcibus_info->pbi_bridge_type,
+	       pcibus_info->pbi_bridge_mode);
+	printk(KERN_INFO "[SN2-PIC-DUMP] host_pci_dev=%s host_slot=%d "
+	       "hub_xid=0x%x\n",
+	       pci_name(pcidev_info->pdi_host_pcidev_info->pdi_linux_pcidev),
+	       host_slot, pcibus_info->pbi_hub_xid);
+	printk(KERN_INFO "[SN2-PIC-DUMP] dir_xbase=0x%llx int_ate_size=%lld "
+	       "valid_dev=0x%x enabled_dev=0x%x\n",
+	       pcibus_info->pbi_dir_xbase,
+	       pcibus_info->pbi_int_ate_size,
+	       pcibus_info->pbi_valid_devices,
+	       pcibus_info->pbi_enabled_devices);
+
+	/* Read PIC registers directly */
+	dir_map = __sn_readq_relaxed(&pic_regs->p_dir_map);
+	rrb_even = __sn_readq_relaxed(&pic_regs->p_even_resp);
+	rrb_odd = __sn_readq_relaxed(&pic_regs->p_odd_resp);
+	int_enable = __sn_readq_relaxed(&pic_regs->p_int_enable);
+	int_status = __sn_readq_relaxed(&pic_regs->p_int_status);
+
+	for (i = 0; i < 4; i++) {
+		device_reg[i] = __sn_readq_relaxed(&pic_regs->p_device[i]);
+		/* Reading p_wr_req_buf flushes WRBs — read for diagnostics */
+		wrb[i] = __sn_readq_relaxed(&pic_regs->p_wr_req_buf[i]);
+	}
+
+	printk(KERN_INFO "[SN2-PIC-DUMP] p_dir_map=0x%016llx\n", dir_map);
+	printk(KERN_INFO "[SN2-PIC-DUMP] p_rrb_map: even=0x%016llx "
+	       "odd=0x%016llx\n", rrb_even, rrb_odd);
+	printk(KERN_INFO "[SN2-PIC-DUMP] p_int_enable=0x%016llx "
+	       "p_int_status=0x%016llx\n", int_enable, int_status);
+	for (i = 0; i < 4; i++)
+		printk(KERN_INFO "[SN2-PIC-DUMP] device[%d]=0x%016llx "
+		       "wrb[%d]=0x%016llx\n",
+		       i, device_reg[i], i, wrb[i]);
+
+	/* Decode RRB allocation: each RRB map has 4-bit fields per slot */
+	printk(KERN_INFO "[SN2-PIC-DUMP] RRB decode (4 bits per slot, "
+	       "8 slots per even/odd):\n");
+	for (i = 0; i < 8; i++) {
+		u64 even_rrb = (rrb_even >> (i * 8)) & 0xff;
+		u64 odd_rrb = (rrb_odd >> (i * 8)) & 0xff;
+		printk(KERN_INFO "[SN2-PIC-DUMP]   rrb[%d]: even=0x%02llx "
+		       "odd=0x%02llx\n", i, even_rrb, odd_rrb);
+	}
+
+	/* Dump flush_nasid_list for this widget */
+	nasid = NASID_GET(pcibus_info->pbi_buscommon.bs_base);
+	cnode = nasid_to_cnodeid(nasid);
+	if (cnode >= 0) {
+		hubinfo = (struct hubdev_info *)(NODEPDA(cnode)->pdinfo);
+		wid_num = SWIN_WIDGETNUM(pcibus_info->pbi_buscommon.bs_base);
+		printk(KERN_INFO "[SN2-PIC-DUMP] nasid=0x%x cnode=%d "
+		       "widget=%d\n", nasid, cnode, wid_num);
+
+		if (hubinfo->hdi_flush_nasid_list.widget_p &&
+		    hubinfo->hdi_flush_nasid_list.widget_p[wid_num]) {
+			fdk = hubinfo->hdi_flush_nasid_list.widget_p[wid_num];
+			for (i = 0; i < DEV_PER_WIDGET; i++, fdk++) {
+				struct sn_flush_device_common *c = fdk->common;
+				if (!c || c->sfdl_slot == -1)
+					continue;
+				/* Only print entries with actual BARs */
+				if (c->sfdl_bar_list[0].start == 0)
+					continue;
+				printk(KERN_INFO "[SN2-PIC-DUMP] flush[%d]: "
+				       "slot=%d pin=%d bus=%d "
+				       "force_int=0x%lx flush_addr=%p\n",
+				       i, c->sfdl_slot, c->sfdl_pin,
+				       c->sfdl_bus,
+				       c->sfdl_force_int_addr,
+				       c->sfdl_flush_addr);
+				for (j = 0; j < 6; j++) {
+					if (c->sfdl_bar_list[j].start == 0)
+						break;
+					printk(KERN_INFO "[SN2-PIC-DUMP]   "
+					       "bar[%d]: 0x%lx - 0x%lx\n",
+					       j, c->sfdl_bar_list[j].start,
+					       c->sfdl_bar_list[j].end);
+				}
+			}
+		} else {
+			printk(KERN_WARNING "[SN2-PIC-DUMP] No flush list for "
+			       "widget %d!\n", wid_num);
+		}
+	}
+
+	printk(KERN_INFO "[SN2-PIC-DUMP] === End PIC Bridge Dump ===\n");
+}
+EXPORT_SYMBOL(sn2_pic_bridge_dump);
