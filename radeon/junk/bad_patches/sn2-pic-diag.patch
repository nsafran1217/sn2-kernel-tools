+	struct pcibus_info *pcibus_info;
+	struct pic __iomem *pic_regs;
+	u64 rrb_even, rrb_odd;
+	u64 new_even, new_odd;
+	u8 host_slot, internal_device;
+	int i, dev_rrb_count;
