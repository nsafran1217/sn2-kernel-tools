+		for (i = 0; i < 8; i++) {
+			new_even |= ((u64)(0x8 | even_devs[i])) << (i * 4);
+			new_odd |= ((u64)(0x8 | odd_devs[i])) << (i * 4);
+		}
+	}
+
+	printk(KERN_INFO "[SN2-RRB] Reallocating: new_even=0x%016llx "
+	       "new_odd=0x%016llx\n", new_even, new_odd);
+	printk(KERN_INFO "[SN2-RRB] Allocation: dev0=4 dev%d=8 dev2=4\n",
+	       internal_device);
+
+	/* Write new RRB map */
+	writeq(new_even, &pic_regs->p_even_resp);
+	writeq(new_odd, &pic_regs->p_odd_resp);
+
+	/* Verify by reading back */
+	rrb_even = __sn_readq_relaxed(&pic_regs->p_even_resp);
+	rrb_odd = __sn_readq_relaxed(&pic_regs->p_odd_resp);
+
+	printk(KERN_INFO "[SN2-RRB] Readback: even=0x%016llx odd=0x%016llx\n",
+	       rrb_even, rrb_odd);
+
+	if (rrb_even != new_even || rrb_odd != new_odd) {
+		printk(KERN_ERR "[SN2-RRB] MISMATCH — RRB realloc may have "
+		       "failed!\n");
+		return -EIO;
+	}
+
+	printk(KERN_INFO "[SN2-RRB] SUCCESS — device %d now has 8 RRBs\n",
+	       internal_device);
+	return 0;
+}
+EXPORT_SYMBOL(sn2_pic_rrb_realloc);
