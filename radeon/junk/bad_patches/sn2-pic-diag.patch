diff --git a/arch/ia64/sn/kernel/iomv.c b/arch/ia64/sn/kernel/iomv.c
index 749a2cf..705bd7b 100644
--- a/arch/ia64/sn/kernel/iomv.c
+++ b/arch/ia64/sn/kernel/iomv.c
@@ -84,3 +84,46 @@ void __sn_mmiowb(void)
 }
 
 EXPORT_SYMBOL(__sn_mmiowb);
+
+/**
+ * sn2_pio_write_status - Read PIO write PENDING count for all CPUs
+ * @counts: array of per-CPU pending write counts (0=idle, 63=full)
+ * @deadlock: array of per-CPU deadlock flags
+ *
+ * Returns the maximum PENDING count across all CPUs.
+ *
+ * IMPORTANT: On SHub1 (Altix 350), the register counts FREE slots,
+ * not occupied ones. 63 = all free (0 pending), 0 = all occupied
+ * (63 pending). The __sn_mmiowb() function confirms this: it spins
+ * until count == pio_write_status_val (0x3f = 63 = "drained").
+ * We invert to report PENDING writes (63 - raw) for clarity.
+ *
+ * [shub_mmr.h: PENDING_WRITE_COUNT bits 61:56, 6-bit field]
+ * [iomv.c: __sn_mmiowb waits for count == 63 = drained]
+ */
+// [DEBUG INSTRUMENTATION]
+int sn2_pio_write_status(u64 *counts, int *deadlock, int max_cpus)
+{
+	int cpu, max_pending = 0;
+
+	for (cpu = 0; cpu < max_cpus && cpu < nr_cpu_ids; cpu++) {
+		struct pda_s *p = &per_cpu(pda_percpu, cpu);
+		if (p->pio_write_status_addr) {
+			u64 raw = *(p->pio_write_status_addr);
+			int free_slots = (raw >> SH_PIO_WRITE_STATUS_PENDING_WRITE_COUNT_SHFT) & 0x3f;
+			int pending = 63 - free_slots;  /* invert: 0=idle, 63=full */
+			int dl = (raw >> SH_PIO_WRITE_STATUS_WRITE_DEADLOCK_SHFT) & 1;
+			if (counts)
+				counts[cpu] = pending;
+			if (deadlock)
+				deadlock[cpu] = dl;
+			if (pending > max_pending)
+				max_pending = pending;
+		} else {
+			if (counts) counts[cpu] = 0;
+			if (deadlock) deadlock[cpu] = 0;
+		}
+	}
+	return max_pending;
+}
+EXPORT_SYMBOL(sn2_pio_write_status);
diff --git a/arch/ia64/sn/pci/pci_dma.c b/arch/ia64/sn/pci/pci_dma.c
index 7b19e0b..c597e07 100644
--- a/arch/ia64/sn/pci/pci_dma.c
+++ b/arch/ia64/sn/pci/pci_dma.c
@@ -18,6 +18,13 @@
 #include <asm/sn/pcibus_provider_defs.h>
 #include <asm/sn/pcidev.h>
 #include <asm/sn/sn_sal.h>
+#include <asm/cacheflush.h>
+#include <linux/scatterlist.h>
+#include <linux/export.h>
+
+/* clflush_cache_range is in arch/ia64/lib/flush.S but not exported.
+ * GPU drivers need it to flush CPU caches before device DMA reads. */
+EXPORT_SYMBOL(clflush_cache_range);
 
 /*
  * DMA_ATTR_WRITE_BARRIER was a DMA attribute (bit 0) originally defined in
@@ -491,6 +498,61 @@ int sn_pci_legacy_write(struct pci_bus *bus, u16 port, u32 val, u8 size)
 	return ret;
 }
 
+/**
+ * sn_dma_sync_single_for_device - flush CPU cache for device DMA access
+ *
+ * On SN2, the directory-based cache coherence protocol (RDEXC) handles
+ * cache consistency for DMA. However, under heavy GPU DMA load, the
+ * FSB intervention table overflows → FSB_PROTO_ERR → MCA.
+ *
+ * Fix: explicitly flush dirty CPU cache lines to memory before the
+ * device reads them. This eliminates RDEXC interventions because the
+ * directory sees "Clean" instead of "Modified in CPU cache".
+ *
+ * Uses ia64 fc (flush cache) instruction via clflush_cache_range().
+ */
+static void sn_dma_sync_single_for_device(struct device *dev,
+					   dma_addr_t dma_handle,
+					   size_t size,
+					   enum dma_data_direction dir)
+{
+	/* Only need to flush for device reads (CPU wrote, device reads) */
+	if (dir == DMA_TO_DEVICE || dir == DMA_BIDIRECTIONAL) {
+		/* Convert DMA address back to virtual.
+		 * Direct32: dma = PCI32_DIRECT_BASE | (phys - dir_xbase)
+		 * For our system dir_xbase=0, so phys = dma & 0x7FFFFFFF
+		 * Kernel virt = __va(phys) */
+		phys_addr_t phys = dma_handle & 0x7FFFFFFFULL;
+		void *vaddr = phys_to_virt(phys);
+		clflush_cache_range(vaddr, size);
+	}
+}
+
+/**
+ * sn_dma_sync_sg_for_device - flush CPU cache for scatter-gather DMA
+ *
+ * Same as above but for scatterlist entries. Each sg entry has
+ * the struct page pointer, so we can get the kernel virtual address
+ * directly without reverse-mapping the DMA address.
+ */
+static void sn_dma_sync_sg_for_device(struct device *dev,
+				       struct scatterlist *sgl,
+				       int nents,
+				       enum dma_data_direction dir)
+{
+	struct scatterlist *sg;
+	int i;
+
+	if (dir == DMA_TO_DEVICE || dir == DMA_BIDIRECTIONAL) {
+		for_each_sg(sgl, sg, nents, i) {
+			void *vaddr = page_address(sg_page(sg));
+			if (vaddr)
+				clflush_cache_range(vaddr + sg->offset,
+						    sg->length);
+		}
+	}
+}
+
