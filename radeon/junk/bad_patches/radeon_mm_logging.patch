diff --git a/drivers/gpu/drm/radeon/r100.c b/drivers/gpu/drm/radeon/r100.c
index 3ac1a79..c959ea8 100644
--- a/drivers/gpu/drm/radeon/r100.c
+++ b/drivers/gpu/drm/radeon/r100.c
@@ -4124,10 +4124,12 @@ uint32_t r100_mm_rreg_slow(struct radeon_device *rdev, uint32_t reg)
 	unsigned long flags;
 	uint32_t ret;
 
+	pr_info("radeon mm_rreg: reg=0x%05x\n", reg);
 	spin_lock_irqsave(&rdev->mmio_idx_lock, flags);
 	writel(reg, ((void __iomem *)rdev->rmmio) + RADEON_MM_INDEX);
 	ret = readl(((void __iomem *)rdev->rmmio) + RADEON_MM_DATA);
 	spin_unlock_irqrestore(&rdev->mmio_idx_lock, flags);
+	pr_info("radeon mm_rreg: reg=0x%05x val=0x%08x\n", reg, ret);
 	return ret;
 }
 
@@ -4135,6 +4137,7 @@ void r100_mm_wreg_slow(struct radeon_device *rdev, uint32_t reg, uint32_t v)
 {
 	unsigned long flags;
 
+	pr_info("radeon mm_wreg: reg=0x%05x val=0x%08x\n", reg, v);
 	spin_lock_irqsave(&rdev->mmio_idx_lock, flags);
 	writel(reg, ((void __iomem *)rdev->rmmio) + RADEON_MM_INDEX);
 	writel(v, ((void __iomem *)rdev->rmmio) + RADEON_MM_DATA);

