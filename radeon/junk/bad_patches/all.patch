diff --git a/drivers/gpu/drm/radeon/radeon_ttm.c b/drivers/gpu/drm/radeon/radeon_ttm.c
index e7ab816..1fdf39a 100644
--- a/drivers/gpu/drm/radeon/radeon_ttm.c
+++ b/drivers/gpu/drm/radeon/radeon_ttm.c
@@ -298,6 +298,25 @@ static int radeon_ttm_io_mem_reserve(struct ttm_device *bdev, struct ttm_resourc
 		 */
 		mem->bus.offset = (mem->bus.offset & 0x0ffffffffUL) +
 			rdev->hose->dense_mem_base;
+#endif
+#ifdef CONFIG_IA64_SGI_SN2
+		/*
+		 * SN2/ia64: pci_resource_start() returns PIO addresses with
+		 * ia64 region bits (63:61) set. aper_base=0x80000008... has
+		 * region 4 (bit 63). The PFN from bus.offset >> PAGE_SHIFT
+		 * overflows ia64's 50-bit physical address space, causing MCA
+		 * when vmf_insert_pfn_prot() builds userspace PTEs.
+		 * Strip region bits — raw phys addr is valid for ia64 PTEs.
+		 * [Identical pattern to Alpha fix above]
+		 */
+		mem->bus.offset &= 0x1FFFFFFFFFFFFFFFULL; /* keep bits 60:0 */
+
+		/* SN2: VRAM accessed via PIO. Write-combining (_PAGE_MA_WC)
+		 * causes CPU write buffers to never flush to PIO space → hang.
+		 * PDF page 67 requires pgprot_noncached() for PCI mem resources.
+		 * Kernel ioremap uses UC (region 6). Userspace PTEs must match.
+		 */
+		mem->bus.caching = ttm_uncached;
 #endif
 		break;
 	default:
