diff --git a/drivers/gpu/drm/radeon/r100.c b/drivers/gpu/drm/radeon/r100.c
index 3ac1a79..6512b3e 100644
--- a/drivers/gpu/drm/radeon/r100.c
+++ b/drivers/gpu/drm/radeon/r100.c
@@ -643,10 +643,16 @@ void r100_hpd_fini(struct radeon_device *rdev)
  */
 void r100_pci_gart_tlb_flush(struct radeon_device *rdev)
 {
-	/* TODO: can we do somethings here ? */
-	/* It seems hw only cache one entry so we should discard this
-	 * entry otherwise if first GPU GART read hit this entry it
-	 * could end up in wrong address. */
+	/* SN2 fix: Toggle PCIGART_TRANSLATE_EN to force AIC cache re-read.
+	 * Without this, stale AIC entries could cause DMA reads to access
+	 * wrong physical pages after GART table updates. */
+	u32 tmp = RREG32(RADEON_AIC_CNTL);
+	WREG32(RADEON_AIC_CNTL, tmp & ~RADEON_PCIGART_TRANSLATE_EN);
+	RREG32(RADEON_AIC_CNTL); /* PIO flush */
+	udelay(10);
+	WREG32(RADEON_AIC_CNTL, tmp);
+	RREG32(RADEON_AIC_CNTL); /* PIO flush */
+	mb();
 }
 
 int r100_pci_gart_init(struct radeon_device *rdev)
@@ -950,8 +956,8 @@ struct radeon_fence *r100_copy_blit(struct radeon_device *rdev,
 				  RADEON_DP_SRC_SOURCE_MEMORY |
 				  RADEON_GMC_CLR_CMP_CNTL_DIS |
 				  RADEON_GMC_WR_MSK_DIS);
-		radeon_ring_write(ring, (pitch << 22) | (src_offset >> 10));
-		radeon_ring_write(ring, (pitch << 22) | (dst_offset >> 10));
+		radeon_ring_write(ring, (pitch << 22) | ((uint32_t)src_offset >> 10));
+		radeon_ring_write(ring, (pitch << 22) | ((uint32_t)dst_offset >> 10));
 		radeon_ring_write(ring, (0x1fff) | (0x1fff << 16));
 		radeon_ring_write(ring, 0);
 		radeon_ring_write(ring, (0x1fff) | (0x1fff << 16));
@@ -1220,7 +1226,16 @@ int r100_cp_init(struct radeon_device *rdev, unsigned ring_size)
 	if (rdev->wb.enabled)
 		WREG32(R_000770_SCRATCH_UMSK, 0xff);
 	else {
+#ifndef CONFIG_IA64_SGI_SN2
+		/* SN2: Do NOT set RB_NO_UPDATE. The R100 CP microcode
+		 * unconditionally writes RPTR to RPTR_ADDR via DMA when
+		 * the ring goes idle. With RB_NO_UPDATE, the DMA still
+		 * happens but RPTR_ADDR might be 0 on other platforms.
+		 * On SN2, bus address 0 has no ATE → DMA never completes
+		 * → RSIU permanently stalls. RPTR_ADDR is already set to
+		 * a valid GART address above (line 1216), so let it write. */
 		tmp |= RADEON_RB_NO_UPDATE;
+#endif
 		WREG32(R_000770_SCRATCH_UMSK, 0);
 	}
 
@@ -3894,6 +3909,18 @@ static void r100_clock_startup(struct radeon_device *rdev)
 	tmp |= S_00000D_FORCE_CP(1) | S_00000D_FORCE_VIP(1);
 	if ((rdev->family == CHIP_RV250) || (rdev->family == CHIP_RV280))
 		tmp |= S_00000D_FORCE_DISP1(1) | S_00000D_FORCE_DISP2(1);
+
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: Without BIOS POST, engine clocks may be gated off.
+	 * Force all engine clocks ON so the rendering pipeline can
+	 * process CP register writes. */
+	if (!rdev->bios) {
+		printk(KERN_INFO "[SN2-DBG] r100_clock_startup: no BIOS, forcing all engine clocks ON\n");
+		WREG32(R_00000D_SCLK_CNTL, 0x1FFF7FFA);
+		return;
+	}
+#endif
+
 	WREG32_PLL(R_00000D_SCLK_CNTL, tmp);
 }
 
diff --git a/drivers/gpu/drm/radeon/radeon_device.c b/drivers/gpu/drm/radeon/radeon_device.c
index 5d523d5..156e07c 100644
--- a/drivers/gpu/drm/radeon/radeon_device.c
+++ b/drivers/gpu/drm/radeon/radeon_device.c
@@ -1301,6 +1301,8 @@ int radeon_device_init(struct radeon_device *rdev,
 		 radeon_family_name[rdev->family], pdev->vendor, pdev->device,
 		 pdev->subsystem_vendor, pdev->subsystem_device, pdev->revision);
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 1 — mutexes\n");
 	/* mutex initialization are all done here so we
 	 * can recall function without having locking issues */
 	mutex_init(&rdev->ring_lock);
@@ -1369,6 +1371,9 @@ int radeon_device_init(struct radeon_device *rdev,
 		dma_bits = 32;
 #endif
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 3 — dma_set_mask\n");
+
 	r = dma_set_mask_and_coherent(&rdev->pdev->dev, DMA_BIT_MASK(dma_bits));
 	if (r) {
 		pr_warn("radeon: No suitable DMA available\n");
@@ -1377,6 +1382,15 @@ int radeon_device_init(struct radeon_device *rdev,
 	rdev->pdev->msi_addr_mask = DMA_BIT_MASK(dma_bits);
 	rdev->need_swiotlb = drm_need_swiotlb(dma_bits);
 
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: drm_need_swiotlb() false positive from NASID-encoded phys addrs.
+	 * With need_swiotlb=true, TTM uses dma_alloc_coherent which creates
+	 * barrier ATEs (PCI32_ATE_BAR) causing WrReqWithResp xtalk packets.
+	 * The PIC bridge rejects WrReqWithResp for devices behind PLX bridge.
+	 * Force streaming DMA (direct32 path, no barrier ATEs). */
+	rdev->need_swiotlb = false;
+#endif
+
 	/* Registers mapping */
 	/* TODO: block userspace mapping of io register */
 	spin_lock_init(&rdev->mmio_idx_lock);
@@ -1398,15 +1412,30 @@ int radeon_device_init(struct radeon_device *rdev,
 		rdev->rmmio_base = pci_resource_start(rdev->pdev, 2);
 		rdev->rmmio_size = pci_resource_len(rdev->pdev, 2);
 	}
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 4 — ioremap\n");
 	rdev->rmmio = ioremap(rdev->rmmio_base, rdev->rmmio_size);
 	if (rdev->rmmio == NULL)
 		return -ENOMEM;
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 5 — io port + vga\n");
+
 	/* doorbell bar mapping */
 	if (rdev->family >= CHIP_BONAIRE)
 		radeon_doorbell_init(rdev);
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 5a — io port loop\n");
+
 	/* io port mapping */
+#ifdef CONFIG_IA64_SGI_SN2
+	/* SN2: pci_iomap for I/O BARs hangs on devices behind PLX bridge.
+	 * SN2 doesn't support legacy I/O port access via PIO anyway.
+	 * ATOM parser falls back to MMIO for IIO operations.
+	 * [PDF §Legacy Functionality / Page 3]: no legacy I/O ports on SN2 */
+	rdev->rio_mem = NULL;
+#else
 	for (i = 0; i < DEVICE_COUNT_RESOURCE; i++) {
 		if (pci_resource_flags(rdev->pdev, i) & IORESOURCE_IO) {
 			rdev->rio_mem_size = pci_resource_len(rdev->pdev, i);
@@ -1414,9 +1443,13 @@ int radeon_device_init(struct radeon_device *rdev,
 			break;
 		}
 	}
+#endif
 	if (rdev->rio_mem == NULL)
 		DRM_ERROR("Unable to find PCI I/O BAR\n");
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 5b — vga_client_register\n");
+
 	if (rdev->flags & RADEON_IS_PX)
 		radeon_device_handle_px_quirks(rdev);
 
@@ -1433,6 +1466,8 @@ int radeon_device_init(struct radeon_device *rdev,
 	if (runtime)
 		vga_switcheroo_init_domain_pm_ops(rdev->dev, &rdev->vga_pm_domain);
 
+	// [DEBUG INSTRUMENTATION]
+	printk(KERN_INFO "[SN2-DBG] radeon_device_init: stage 6 — radeon_init\n");
 	r = radeon_init(rdev);
 	if (r)
 		goto failed;
diff --git a/drivers/gpu/drm/radeon/radeon_fbdev.c b/drivers/gpu/drm/radeon/radeon_fbdev.c
