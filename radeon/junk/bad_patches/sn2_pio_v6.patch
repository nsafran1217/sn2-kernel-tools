--- a/drivers/gpu/drm/radeon/radeon.h
+++ b/drivers/gpu/drm/radeon/radeon.h
@@ -2455,18 +2455,53 @@
 				    bool always_indirect)
 {
 	/* The mmio size is 64kb at minimum. Allows the if to be optimized out. */
-	if ((reg < rdev->rmmio_size || reg < RADEON_MIN_MMIO_SIZE) && !always_indirect)
+	if ((reg < rdev->rmmio_size || reg < RADEON_MIN_MMIO_SIZE) && !always_indirect) {
+#ifdef CONFIG_IA64_SGI_SN2
+		/*
+		 * SN2: Bypass sn_dma_flush() which readl() calls on every read.
+		 * sn_dma_flush() writes to PIC force-interrupt registers, generating
+		 * 3 extra xtalk ops per read. This concurrent PIC register traffic
+		 * interleaved with GPU PIO causes xtalk command word corruption.
+		 * Userspace mmap PIO (which skips sn_dma_flush) never crashes.
+		 */
+		uint32_t val = *(volatile uint32_t __force *)
+			(((void __iomem *)rdev->rmmio) + reg);
+		ia64_mfa();
+		return val;
+#else
 		return readl(((void __iomem *)rdev->rmmio) + reg);
-	else
+#endif
+	} else
 		return r100_mm_rreg_slow(rdev, reg);
 }
+#ifdef CONFIG_IA64_SGI_SN2
+extern u32 sn2_pio_trace_reg[];
+extern u32 sn2_pio_trace_val[];
+extern u64 sn2_pio_trace_cnt[];
+extern unsigned int sn2_pio_trace_idx;
+extern u64 sn2_pio_trace_total;
+extern void __sn_mmiowb(void);
+#endif
+
 static inline void r100_mm_wreg(struct radeon_device *rdev, uint32_t reg, uint32_t v,
 				bool always_indirect)
 {
+#ifdef CONFIG_IA64_SGI_SN2
+	{
+		unsigned int idx = sn2_pio_trace_idx;
+		sn2_pio_trace_reg[idx] = reg;
+		sn2_pio_trace_val[idx] = v;
+		sn2_pio_trace_cnt[idx] = ++sn2_pio_trace_total;
+		sn2_pio_trace_idx = (idx + 1) & 31;
+	}
+#endif
 	if ((reg < rdev->rmmio_size || reg < RADEON_MIN_MMIO_SIZE) && !always_indirect)
 		writel(v, ((void __iomem *)rdev->rmmio) + reg);
 	else
 		r100_mm_wreg_slow(rdev, reg, v);
+#ifdef CONFIG_IA64_SGI_SN2
+	__sn_mmiowb();
+#endif
 }
 
 u32 r100_io_rreg(struct radeon_device *rdev, u32 reg);
