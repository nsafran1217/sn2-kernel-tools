+			       "MA_bits=0x%lx\n",
+			       man->use_tt, caching,
+			       pgprot_val(tmp), pgprot_val(result),
+			       (pgprot_val(result) >> 2) & 0x7);
+			log_count++;
+		}
+		return result;
+	}
+#endif
+
