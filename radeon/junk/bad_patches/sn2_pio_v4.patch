 int
 sal_pcibr_slot_enable(struct pcibus_info *soft, int device, void *resp,
@@ -95,6 +97,50 @@
 	return ioboard;
 }
 
+/*
+ * SN2 GPU PIO write trace ring buffer.
+ */
+u32 sn2_pio_trace_reg[32];
+u32 sn2_pio_trace_val[32];
+u64 sn2_pio_trace_cnt[32];
+unsigned int sn2_pio_trace_idx;
+u64 sn2_pio_trace_total;
+EXPORT_SYMBOL(sn2_pio_trace_reg);
+EXPORT_SYMBOL(sn2_pio_trace_val);
+EXPORT_SYMBOL(sn2_pio_trace_cnt);
+EXPORT_SYMBOL(sn2_pio_trace_idx);
+EXPORT_SYMBOL(sn2_pio_trace_total);
+
+static void sn2_pio_trace_dump(void)
+{
+	int i, idx;
+	unsigned long pio_status = 0;
+
+	/* Read SHUB PIO write status */
+	if (pda->pio_write_status_addr)
+		pio_status = *(volatile unsigned long *)pda->pio_write_status_addr;
+	pr_crit("SN2_PIO: SHUB PIO_WRITE_STATUS=0x%lx (pending=%lu deadlock=%lu)\n",
+		pio_status,
+		(pio_status >> 56) & 0x3f,
+		(pio_status >> 1) & 1);
+
+	if (!sn2_pio_trace_total) {
+		pr_crit("SN2_PIO: No GPU register writes recorded\n");
+		return;
+	}
+	pr_crit("SN2_PIO: Last 32 GPU register writes (total=%llu):\n",
+		sn2_pio_trace_total);
+	idx = sn2_pio_trace_idx;
+	for (i = 0; i < 32; i++) {
+		int j = (idx + i) & 31;
+		if (sn2_pio_trace_cnt[j])
+			pr_crit("SN2_PIO:  [%llu] reg=0x%04x val=0x%08x\n",
+				sn2_pio_trace_cnt[j],
+				sn2_pio_trace_reg[j],
+				sn2_pio_trace_val[j]);
+	}
+}
