From 31a478ef6c9ef5fa6dbea9a0df26d18b1b8ed8ac Mon Sep 17 00:00:00 2001
From: Debug <debug@sn2>
Date: Fri, 10 Apr 2026 17:25:24 +0000
Subject: [PATCH 2/2] ia64/sn2: add DMA mapping debug instrumentation

Add printk instrumentation to the SN2 DMA mapping path to trace
DMA address translation for devices behind PCI bridges.

Instruments:
- sn_dma_map_phys: NULL provider check, log phys/dma/mask for
  devices on secondary buses
- pcibr_dma_map: log which DMA path (direct64/direct32/ate32),
  physical address, and resulting DMA bus address
- pcibr_dma_map_consistent: same for consistent mappings

Filtered to only log for devices on bus != 0 (behind bridges)
to avoid flooding from native bus devices. Uses dev_info_ratelimited.

All messages prefixed with SN2_DEBUG for easy grep.
---
 arch/ia64/sn/pci/pci_dma.c         | 14 ++++++++++++++
 arch/ia64/sn/pci/pcibr/pcibr_dma.c | 21 +++++++++++++++++++++
 2 files changed, 35 insertions(+)

diff --git a/arch/ia64/sn/pci/pci_dma.c b/arch/ia64/sn/pci/pci_dma.c
index 7b19e0b..3a59a0c 100644
--- a/arch/ia64/sn/pci/pci_dma.c
+++ b/arch/ia64/sn/pci/pci_dma.c
@@ -225,6 +225,12 @@ static dma_addr_t sn_dma_map_phys(struct device *dev, phys_addr_t phys,
 		return DMA_MAPPING_ERROR;
 	provider = pcidev_info->pdi_provider;
 
+	if (!provider) {
+		dev_err_once(dev, "SN2_DEBUG: sn_dma_map_phys: NULL provider for %s!\n",
+			     pci_name(pdev));
+		return DMA_MAPPING_ERROR;
+	}
+
 	if (attrs & DMA_ATTR_WRITE_BARRIER)
 		dma_addr = provider->dma_map_consistent(pdev, phys,
 							size, SN_DMA_ADDR_PHYS);
@@ -232,6 +238,14 @@ static dma_addr_t sn_dma_map_phys(struct device *dev, phys_addr_t phys,
 		dma_addr = provider->dma_map(pdev, phys, size,
 					     SN_DMA_ADDR_PHYS);
 
+	/* Log DMA mappings for devices on secondary buses (behind bridges) */
+	if (pdev->bus->number != 0) {
+		dev_info_ratelimited(dev,
+			"SN2_DEBUG: dma_map %s phys=0x%llx size=%zu dma=0x%llx mask=0x%llx dir=%d\n",
+			pci_name(pdev), (u64)phys, size, (u64)dma_addr,
+			pdev->dma_mask, dir);
+	}
+
 	if (!dma_addr) {
 		printk(KERN_ERR "%s: out of ATEs\n", __func__);
 		return DMA_MAPPING_ERROR;
diff --git a/arch/ia64/sn/pci/pcibr/pcibr_dma.c b/arch/ia64/sn/pci/pcibr/pcibr_dma.c
index 8a4a67b..dd854c6 100644
--- a/arch/ia64/sn/pci/pcibr/pcibr_dma.c
+++ b/arch/ia64/sn/pci/pcibr/pcibr_dma.c
@@ -362,6 +362,7 @@ pcibr_dma_map(struct pci_dev * hwdev, unsigned long phys_addr, size_t size, int
 {
 	dma_addr_t dma_handle;
 	struct pcidev_info *pcidev_info = SN_PCIDEV_INFO(hwdev);
+	const char *path;
 
 	if (!pcidev_info)
 		return 0;
@@ -379,6 +380,7 @@ pcibr_dma_map(struct pci_dev * hwdev, unsigned long phys_addr, size_t size, int
 
 		dma_handle = pcibr_dmatrans_direct64(pcidev_info, phys_addr,
 						     PCI64_ATTR_PREF, dma_flags);
+		path = "direct64";
 	} else {
 		/* Handle 32-63 bit cards via direct mapping */
 		dma_handle = pcibr_dmatrans_direct32(pcidev_info, phys_addr,
@@ -392,9 +394,20 @@ pcibr_dma_map(struct pci_dev * hwdev, unsigned long phys_addr, size_t size, int
 			dma_handle = pcibr_dmamap_ate32(pcidev_info, phys_addr,
 							size, PCI32_ATE_PREF,
 							dma_flags);
+			path = "ate32";
+		} else {
+			path = "direct32";
 		}
 	}
 
+	/* Log for devices behind bridges */
+	if (hwdev->bus->number != 0) {
+		dev_info_ratelimited(&hwdev->dev,
+			"SN2_DEBUG: pcibr_dma_map %s phys=0x%lx size=%zu dma=0x%llx path=%s mask=0x%llx\n",
+			pci_name(hwdev), phys_addr, size,
+			(unsigned long long)dma_handle, path, hwdev->dma_mask);
+	}
+
 	return dma_handle;
 }
 
@@ -417,6 +430,14 @@ pcibr_dma_map_consistent(struct pci_dev * hwdev, unsigned long phys_addr,
 						    PCI32_ATE_BAR, dma_flags);
 	}
 
+	if (hwdev->bus->number != 0) {
+		dev_info_ratelimited(&hwdev->dev,
+			"SN2_DEBUG: pcibr_dma_map_consistent %s phys=0x%lx size=%zu dma=0x%llx coherent_mask=0x%llx\n",
+			pci_name(hwdev), phys_addr, size,
+			(unsigned long long)dma_handle,
+			hwdev->dev.coherent_dma_mask);
+	}
+
 	return dma_handle;
 }
 
