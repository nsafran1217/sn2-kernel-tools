@@ -4119,15 +4119,88 @@ int r100_init(struct radeon_device *rdev)
 	return 0;
 }
 
+/*
+ * SN2 PIO Trace Ring Buffer
+ *
+ * Records the last 256 register writes for post-mortem debugging.
+ * Dumped via radeon_pio_trace_dump() which is registered as
+ * pcibr_error_dump_hook so it fires on every PIC bridge error.
+ */
+#ifdef CONFIG_IA64_SGI_SN2
+
+#define RADEON_PIO_TRACE_SIZE 256
+#define RADEON_PIO_TRACE_MASK (RADEON_PIO_TRACE_SIZE - 1)
+
+struct radeon_pio_trace_entry {
+	u32 reg;
+	u32 val;
+	u8  rw;   /* 0=write, 1=read */
+	unsigned long jiffies;
+	void *caller;
+};
+
+static struct radeon_pio_trace_entry radeon_pio_trace_buf[RADEON_PIO_TRACE_SIZE];
+static atomic_t radeon_pio_trace_idx = ATOMIC_INIT(0);
+
+static inline void radeon_pio_trace_record(u32 reg, u32 val, u8 rw)
+{
+	int idx = atomic_inc_return(&radeon_pio_trace_idx) & RADEON_PIO_TRACE_MASK;
+	radeon_pio_trace_buf[idx].reg    = reg;
+	radeon_pio_trace_buf[idx].val    = val;
+	radeon_pio_trace_buf[idx].rw     = rw;
+	radeon_pio_trace_buf[idx].jiffies = jiffies;
+	radeon_pio_trace_buf[idx].caller = __builtin_return_address(0);
+}
+
+void radeon_pio_trace_dump(const char *reason)
+{
+	int cur = atomic_read(&radeon_pio_trace_idx);
+	int i, idx;
+
+	pr_err("=== RADEON PIO TRACE DUMP (%s) last %d ops ===\n",
+	       reason, RADEON_PIO_TRACE_SIZE);
+	for (i = 0; i < RADEON_PIO_TRACE_SIZE; i++) {
+		idx = (cur - RADEON_PIO_TRACE_SIZE + 1 + i) & RADEON_PIO_TRACE_MASK;
+		if (radeon_pio_trace_buf[idx].jiffies == 0)
+			continue;
+		pr_err("  PIO[%03d] %s reg=0x%05x val=0x%08x j=%lu [%pS]\n",
+		       i,
+		       radeon_pio_trace_buf[idx].rw ? " RD" : " WR",
+		       radeon_pio_trace_buf[idx].reg,
+		       radeon_pio_trace_buf[idx].val,
+		       radeon_pio_trace_buf[idx].jiffies,
+		       radeon_pio_trace_buf[idx].caller);
+	}
+	pr_err("=== RADEON PIO TRACE DUMP END ===\n");
+}
+EXPORT_SYMBOL(radeon_pio_trace_dump);
+
+/* Check if PIC bridge error has frozen PIO — if so, abort silently */
+static inline bool radeon_pio_is_frozen(void)
+{
+	extern atomic_t pcibr_pio_frozen;
+	return atomic_read(&pcibr_pio_frozen) != 0;
+}
+
+#endif /* CONFIG_IA64_SGI_SN2 */
+
 uint32_t r100_mm_rreg_slow(struct radeon_device *rdev, uint32_t reg)
 {
 	unsigned long flags;
 	uint32_t ret;
 
+#ifdef CONFIG_IA64_SGI_SN2
+	if (radeon_pio_is_frozen())
+		return 0;
+#endif
+
 	spin_lock_irqsave(&rdev->mmio_idx_lock, flags);
 	writel(reg, ((void __iomem *)rdev->rmmio) + RADEON_MM_INDEX);
 	ret = readl(((void __iomem *)rdev->rmmio) + RADEON_MM_DATA);
 	spin_unlock_irqrestore(&rdev->mmio_idx_lock, flags);
+#ifdef CONFIG_IA64_SGI_SN2
+	radeon_pio_trace_record(reg, ret, 1);
+#endif
 	return ret;
 }
 
@@ -4135,6 +4208,12 @@ void r100_mm_wreg_slow(struct radeon_device *rdev, uint32_t reg, uint32_t v)
 {
 	unsigned long flags;
 
+#ifdef CONFIG_IA64_SGI_SN2
+	if (radeon_pio_is_frozen())
+		return;
+	radeon_pio_trace_record(reg, v, 0);
+#endif
+
 	spin_lock_irqsave(&rdev->mmio_idx_lock, flags);
 	writel(reg, ((void __iomem *)rdev->rmmio) + RADEON_MM_INDEX);
 	writel(v, ((void __iomem *)rdev->rmmio) + RADEON_MM_DATA);
