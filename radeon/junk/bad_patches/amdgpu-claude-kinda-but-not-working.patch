+/**
+ * SN2 PIO Trace Ring Buffer
+ *
+ * Records the last PIO_TRACE_SIZE register writes for post-mortem debugging.
+ * Auto-dumps via printk when amdgpu_pio_trace_dump() is called.
+ */
+#define PIO_TRACE_SIZE 256
+#define PIO_TRACE_MASK (PIO_TRACE_SIZE - 1)
+
+struct pio_trace_entry {
+	u32 reg;
+	u32 val;
+	u32 rw;     /* 0=write, 1=read */
+	unsigned long jiffies;
+	void *caller;
+};
+
+static struct pio_trace_entry pio_trace_buf[PIO_TRACE_SIZE];
+static atomic_t pio_trace_idx = ATOMIC_INIT(0);
+static unsigned long pio_trace_last_dump;
+
+static inline void pio_trace_record(u32 reg, u32 val, u32 rw,
+				    void *caller)
+{
+	int idx = atomic_inc_return(&pio_trace_idx) & PIO_TRACE_MASK;
+	pio_trace_buf[idx].reg = reg;
+	pio_trace_buf[idx].val = val;
+	pio_trace_buf[idx].rw = rw;
+	pio_trace_buf[idx].jiffies = jiffies;
+	pio_trace_buf[idx].caller = caller;
+}
+
+void amdgpu_pio_trace_dump(const char *reason)
+{
+	int cur = atomic_read(&pio_trace_idx);
+	int i, idx;
+
+	/* Rate limit dumps to once per 10 seconds */
+	if (time_before(jiffies, pio_trace_last_dump + 10 * HZ))
+		return;
+	pio_trace_last_dump = jiffies;
+
+	printk(KERN_ERR "=== PIO TRACE DUMP (%s) last %d ops ===\n",
+	       reason, PIO_TRACE_SIZE);
+	for (i = 0; i < PIO_TRACE_SIZE; i++) {
+		idx = (cur - PIO_TRACE_SIZE + 1 + i) & PIO_TRACE_MASK;
+		if (pio_trace_buf[idx].jiffies == 0)
+			continue;
+		printk(KERN_ERR "  PIO[%03d] %s reg=0x%04x val=0x%08x j=%lu [%pS]\n",
+		       i,
+		       pio_trace_buf[idx].rw ? " RD" : " WR",
+		       pio_trace_buf[idx].reg * 4,
+		       pio_trace_buf[idx].val,
+		       pio_trace_buf[idx].jiffies,
+		       pio_trace_buf[idx].caller);
+	}
+	printk(KERN_ERR "=== PIO TRACE DUMP END ===\n");
+}
+EXPORT_SYMBOL(amdgpu_pio_trace_dump);
