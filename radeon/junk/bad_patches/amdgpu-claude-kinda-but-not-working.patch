+/**
+ * amdgpu_irq_poll_timer_fn - periodic IRQ polling callback
+ *
+ * @t: timer_list pointer
+ *
+ * For platforms where hardware interrupt delivery is broken (e.g. SGI Altix
+ * SN2 with devices behind PLX PCI bridges), this timer periodically calls
+ * the IH processor to drain the GPU's interrupt ring buffer. This ensures
+ * vblank events, fence completions, and other interrupt-driven functionality
+ * work without depending on hardware IRQ delivery.
+ */
+static void amdgpu_irq_poll_timer_fn(struct timer_list *t)
+{
+	struct amdgpu_irq *irq = timer_container_of(irq, t, irq_poll_timer);
+	struct amdgpu_device *adev = container_of(irq, struct amdgpu_device, irq);
+	static unsigned long stall_start;
+	static uint32_t stall_last_seq;
+	int i;
+	bool ring_stuck = false;
+
+	amdgpu_ih_process(adev, &adev->irq.ih);
+
+	/* Stall watchdog: check if any ring has pending fences not progressing */
+	for (i = 0; i < AMDGPU_MAX_RINGS; i++) {
+		struct amdgpu_ring *ring = adev->rings[i];
+
+		if (!ring || !ring->sched.ready)
+			continue;
+		if (ring->fence_drv.sync_seq !=
+		    atomic_read(&ring->fence_drv.last_seq)) {
+			ring_stuck = true;
+			break;
+		}
+	}
+
+	if (ring_stuck) {
+		uint32_t cur_seq = atomic_read(&adev->rings[i]->fence_drv.last_seq);
+
+		if (stall_start == 0) {
+			/* First detection of pending fences */
+			stall_start = jiffies;
+			stall_last_seq = cur_seq;
+		} else if (cur_seq == stall_last_seq &&
+			   time_after(jiffies, stall_start + 3 * HZ)) {
+			/* Fence hasn't moved in 3 seconds - dump trace */
+			extern void amdgpu_pio_trace_dump(const char *reason);
+			printk(KERN_ERR "SN2_DEBUG: ring '%s' stalled! "
+			       "sync_seq=%u last_seq=%u for %lu ms\n",
+			       adev->rings[i]->name,
+			       adev->rings[i]->fence_drv.sync_seq,
+			       cur_seq,
+			       jiffies_to_msecs(jiffies - stall_start));
+			amdgpu_pio_trace_dump("FENCE_STALL");
+			stall_start = jiffies; /* reset to avoid spamming */
+		} else if (cur_seq != stall_last_seq) {
+			/* Fence moved - reset watchdog */
+			stall_start = jiffies;
+			stall_last_seq = cur_seq;
+		}
+	} else {
+		stall_start = 0;
+	}
+
+	/* re-arm the timer */
+	if (irq->irq_poll_enabled)
+		mod_timer(&irq->irq_poll_timer,
+			  jiffies + msecs_to_jiffies(amdgpu_irq_poll_interval));
+}
