 static irqreturn_t
 pcibr_error_intr_handler(int irq, void *arg)
 {
 	struct pcibus_info *soft = arg;
+	int ret;
+	int count;
+
+	/* Freeze PIO IMMEDIATELY to prevent cascade to MCA */
+	atomic_set(&pcibr_pio_frozen, 1);
+
+	ret = sal_pcibr_error_interrupt(soft);
+	count = atomic_inc_return(&pcibr_error_count);
+
+	if (ret < 0) {
+		printk(KERN_ERR "pcibr_error_intr_handler(): Bridge Error #%d "
+		       "(SAL returned %d) - PIO FROZEN\n",
+		       count, ret);
+	} else {
+		printk(KERN_WARNING "pcibr_error_intr_handler(): Bridge Error #%d "
+		       "(non-fatal, SAL returned %d) - PIO FROZEN\n",
+		       count, ret);
+	}
 
-	if (sal_pcibr_error_interrupt(soft) < 0)
-		panic("pcibr_error_intr_handler(): Fatal Bridge Error");
+	/* Dump GPU PIO trace if hook is registered */
+	if (pcibr_error_dump_hook)
+		pcibr_error_dump_hook("PIC_BRIDGE_ERROR");
 
 	return IRQ_HANDLED;
 }
