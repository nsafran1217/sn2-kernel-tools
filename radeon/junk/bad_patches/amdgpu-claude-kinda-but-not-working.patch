+static atomic_t pcibr_error_count = ATOMIC_INIT(0);
+
+/* Hook for GPU driver to dump PIO trace on bridge errors */
+void (*pcibr_error_dump_hook)(const char *reason);
+EXPORT_SYMBOL(pcibr_error_dump_hook);
+
+/* Global PIO freeze flag - set on bridge error to stop all device PIO */
+atomic_t pcibr_pio_frozen = ATOMIC_INIT(0);
+EXPORT_SYMBOL(pcibr_pio_frozen);
