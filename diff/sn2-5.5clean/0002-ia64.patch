Subject: [PATCH 2/6] ia64: add machvec.h compatibility shim for SN2

Minimal machvec.h that provides compile-time platform identification.
Defines ia64_platform_is() as a static inline that resolves to strcmp
against "sn2" or "dig" depending on CONFIG_IA64_SGI_SN2. The compiler
optimizes string literal comparisons to constants, so this is zero-cost.

This replaces the full machvec dispatch infrastructure that was removed
when SN2 was dropped. SN2 code calls ia64_platform_is("sn2") ~19 times;
this shim satisfies all of them without runtime function pointer tables.

---

--- a/arch/ia64/include/asm/machvec.h	1970-01-01 00:00:00.000000000 +0000
+++ b/arch/ia64/include/asm/machvec.h	2026-03-08 04:03:38.245480717 +0000
@@ -0,0 +1,37 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Minimal machine vector compatibility shim for SN2 support.
+ *
+ * The full machvec dispatch infrastructure was removed in v5.4.
+ * This header provides compile-time platform identification so that
+ * SN2 platform code and drivers can use ia64_platform_is("sn2")
+ * without requiring the runtime dispatch system.
+ */
+#ifndef _ASM_IA64_MACHVEC_H
+#define _ASM_IA64_MACHVEC_H
+
+#include <linux/string.h>
+
+#ifdef CONFIG_IA64_SGI_SN2
+
+static inline int ia64_platform_is(const char *name)
+{
+	return strcmp(name, "sn2") == 0;
+}
+
+#define ia64_platform_name	"sn2"
+#define ia64_platform_is	ia64_platform_is
+
+#else /* !CONFIG_IA64_SGI_SN2 */
+
+static inline int ia64_platform_is(const char *name)
+{
+	return strcmp(name, "dig") == 0;
+}
+
+#define ia64_platform_name	"dig"
+#define ia64_platform_is	ia64_platform_is
+
+#endif /* CONFIG_IA64_SGI_SN2 */
+
+#endif /* _ASM_IA64_MACHVEC_H */
diff -ruN --no-dereference '--exclude=*.rej' '--exclude=*.orig' arch.clean/ia64/include/asm/mmiowb.h arch/ia64/include/asm/mmiowb.h
