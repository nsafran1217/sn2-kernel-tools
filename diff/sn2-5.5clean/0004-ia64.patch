diff -ruN --no-dereference '--exclude=*.rej' '--exclude=*.orig' arch.clean/ia64/kernel/sal.c arch/ia64/kernel/sal.c
--- a/arch/ia64/kernel/sal.c	2026-03-08 02:38:22.000000000 +0000
