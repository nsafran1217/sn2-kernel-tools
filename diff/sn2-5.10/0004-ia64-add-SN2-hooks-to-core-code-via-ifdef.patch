Subject: [PATCH 4/6] ia64: add SN2 hooks to core code via ifdef

---
 12 files changed

diff -ruN --no-dereference a/arch/ia64/include/asm/hw_irq.h b/arch/ia64/include/asm/hw_irq.h
--- a/arch/ia64/include/asm/hw_irq.h	2026-03-08 15:07:45.000000000 +0000
+++ b/arch/ia64/include/asm/hw_irq.h	2026-03-08 16:03:33.854178429 +0000
@@ -151,7 +151,11 @@
 static inline ia64_vector
 irq_to_vector (int irq)
 {
+#ifdef CONFIG_IA64_SGI_SN2
+	return (ia64_vector)irq;
+#else
 	return irq_cfg[irq].vector;
+#endif
 }
 
 /*
@@ -162,7 +166,11 @@
 static inline unsigned int
 local_vector_to_irq (ia64_vector vec)
 {
