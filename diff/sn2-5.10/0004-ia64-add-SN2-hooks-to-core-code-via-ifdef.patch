diff -ruN --no-dereference a/arch/ia64/kernel/sal.c b/arch/ia64/kernel/sal.c
--- a/arch/ia64/kernel/sal.c	2026-03-08 15:07:45.000000000 +0000
+++ b/arch/ia64/kernel/sal.c	2026-03-08 16:03:33.894178422 +0000
@@ -15,6 +15,7 @@
 #include <linux/string.h>
 
 #include <asm/delay.h>
+#include <asm/machvec.h>
 #include <asm/page.h>
 #include <asm/sal.h>
 #include <asm/pal.h>
@@ -111,6 +112,13 @@
 		sal_revision = SAL_VERSION_CODE(2, 8);
 		sal_version = SAL_VERSION_CODE(0, 0);
 	}
+
+	if (ia64_platform_is("sn2") && (sal_revision == SAL_VERSION_CODE(2, 9)))
+		/*
+		 * SGI Altix has hard-coded version 2.9 in their prom
+		 * but they actually implement 3.2, so let's fix it here.
+		 */
