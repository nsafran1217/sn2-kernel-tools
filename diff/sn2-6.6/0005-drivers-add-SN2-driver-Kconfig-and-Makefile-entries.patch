Subject: [PATCH 5/6] drivers: Add SN2 driver Kconfig and Makefile entries

drivers: Add SN2 driver Kconfig and Makefile entries

Add build system entries for SN2 drivers:
  - drivers/Kconfig, drivers/Makefile: IOC4 and SN
  - drivers/char/Kconfig, Makefile: SNSC, TIOCX, MBCS
  - drivers/char/agp/Kconfig, Makefile: SGI TIOCA AGP
  - drivers/misc/Kconfig, Makefile: IOC4
  - drivers/tty/serial/Kconfig, Makefile: IOC4 serial, SN console
  - drivers/iommu/Kconfig: IOMMU_HELPER dependency
  - drivers/pci/hotplug/Kconfig, Makefile: SGI hotplug
  - include/linux/pci_ids.h: SGI PCI IDs

---

diff -ruN clean/drivers/Kconfig work/drivers/Kconfig
--- clean/drivers/Kconfig	2026-03-10 21:13:36.000000000 +0000
+++ work/drivers/Kconfig	2026-03-10 21:16:07.000000000 +0000
@@ -35,6 +35,8 @@
 
 source "drivers/nvme/Kconfig"
 
+# misc before ide - BLK_DEV_SGIIOC4 depends on SGI_IOC4
+
 source "drivers/misc/Kconfig"
 
 source "drivers/scsi/Kconfig"
diff -ruN clean/drivers/Makefile work/drivers/Makefile
--- clean/drivers/Makefile	2026-03-10 21:13:36.000000000 +0000
+++ work/drivers/Makefile	2026-03-10 21:16:07.000000000 +0000
@@ -138,6 +138,7 @@
 obj-$(CONFIG_MEMSTICK)		+= memstick/
 obj-$(CONFIG_NEW_LEDS)		+= leds/
 obj-$(CONFIG_INFINIBAND)	+= infiniband/
+obj-$(CONFIG_SGI_SN)		+= sn/
 obj-y				+= firmware/
 obj-$(CONFIG_CRYPTO)		+= crypto/
 obj-$(CONFIG_SUPERH)		+= sh/
diff -ruN clean/drivers/char/Kconfig work/drivers/char/Kconfig
--- clean/drivers/char/Kconfig	2026-03-10 21:13:37.000000000 +0000
+++ work/drivers/char/Kconfig	2026-03-10 21:16:07.000000000 +0000
@@ -422,4 +422,26 @@
 	  and SSM (Silicon Secured Memory).  Intended consumers of this
 	  driver include crash and makedumpfile.
 
+config SGI_SNSC
+	bool "SGI Altix system controller communication support"
+	depends on (IA64_SGI_SN2 || IA64_GENERIC)
+	help
+	  If you have an SGI Altix and you want to enable system
+	  controller communication from user space (you want this!),
+	  say Y.  Otherwise, say N.
+
+config SGI_TIOCX
+       bool "SGI TIO CX driver support"
+       depends on (IA64_SGI_SN2 || IA64_GENERIC)
+       help
+         If you have an SGI Altix and you have fpga devices attached
+         to your TIO, say Y here, otherwise say N.
+
+config SGI_MBCS
+       tristate "SGI FPGA Core Services driver support"
+       depends on SGI_TIOCX
+       help
+         If you have an SGI Altix with an attached SABrick
+         say Y or M here, otherwise say N.
+
 endmenu
diff -ruN clean/drivers/char/Makefile work/drivers/char/Makefile
--- clean/drivers/char/Makefile	2026-03-10 21:13:37.000000000 +0000
+++ work/drivers/char/Makefile	2026-03-10 21:16:07.000000000 +0000
@@ -8,9 +8,11 @@
 obj-y				+= misc.o
 obj-$(CONFIG_ATARI_DSP56K)	+= dsp56k.o
 obj-$(CONFIG_VIRTIO_CONSOLE)	+= virtio_console.o
+obj-$(CONFIG_SGI_SNSC)		+= snsc.o snsc_event.o
 obj-$(CONFIG_MSPEC)		+= mspec.o
 obj-$(CONFIG_UV_MMTIMER)	+= uv_mmtimer.o
 obj-$(CONFIG_IBM_BSR)		+= bsr.o
+obj-$(CONFIG_SGI_MBCS)		+= mbcs.o
 
 obj-$(CONFIG_PRINTER)		+= lp.o
 
diff -ruN clean/drivers/char/agp/Kconfig work/drivers/char/agp/Kconfig
--- clean/drivers/char/agp/Kconfig	2026-03-10 21:13:37.000000000 +0000
+++ work/drivers/char/agp/Kconfig	2026-03-10 21:16:07.000000000 +0000
@@ -150,6 +150,13 @@
 	  This option gives you AGP support for the Transmeta Efficeon
 	  series processors with integrated northbridges.
 
+config AGP_SGI_TIOCA
+        tristate "SGI TIO chipset AGP support"
+        depends on AGP && (IA64_SGI_SN2 || IA64_GENERIC)
+        help
+          This option gives you AGP GART support for the SGI TIO chipset
+          for IA64 processors.
+
 config INTEL_GTT
 	tristate
 	depends on X86 && PCI
diff -ruN clean/drivers/char/agp/Makefile work/drivers/char/agp/Makefile
--- clean/drivers/char/agp/Makefile	2026-03-10 21:13:37.000000000 +0000
+++ work/drivers/char/agp/Makefile	2026-03-10 21:16:07.000000000 +0000
@@ -20,6 +20,7 @@
 obj-$(CONFIG_AGP_INTEL)		+= intel-agp.o
 obj-$(CONFIG_INTEL_GTT)		+= intel-gtt.o
 obj-$(CONFIG_AGP_NVIDIA)	+= nvidia-agp.o
+obj-$(CONFIG_AGP_SGI_TIOCA)	+= sgi-agp.o
 obj-$(CONFIG_AGP_SIS)		+= sis-agp.o
 obj-$(CONFIG_AGP_SWORKS)	+= sworks-agp.o
 obj-$(CONFIG_AGP_UNINORTH)	+= uninorth-agp.o
diff -ruN clean/drivers/misc/Kconfig work/drivers/misc/Kconfig
--- clean/drivers/misc/Kconfig	2026-03-10 21:13:38.000000000 +0000
+++ work/drivers/misc/Kconfig	2026-03-10 21:16:07.000000000 +0000
@@ -104,6 +104,18 @@
 	  If you choose to build module, its name will be phantom. If unsure,
 	  say N here.
 
+config SGI_IOC4
+	tristate "SGI IOC4 Base IO support"
+	depends on PCI
+	help
+	  This option enables basic support for the IOC4 chip on certain
+	  SGI IO controller cards (IO9, IO10, and PCI-RT).  This option
+	  does not enable any specific functions on such a card, but provides
+	  necessary infrastructure for other drivers to utilize.
+
+	  If you have an SGI Altix with an IOC4-based card say Y.
+	  Otherwise say N.
+
 config TIFM_CORE
 	tristate "TI Flash Media interface support"
 	depends on PCI
diff -ruN clean/drivers/misc/Makefile work/drivers/misc/Makefile
--- clean/drivers/misc/Makefile	2026-03-10 21:13:38.000000000 +0000
+++ work/drivers/misc/Makefile	2026-03-10 21:16:07.000000000 +0000
@@ -19,6 +19,7 @@
 obj-$(CONFIG_QCOM_FASTRPC)	+= fastrpc.o
 obj-$(CONFIG_SENSORS_BH1770)	+= bh1770glc.o
 obj-$(CONFIG_SENSORS_APDS990X)	+= apds990x.o
+obj-$(CONFIG_SGI_IOC4)		+= ioc4.o
 obj-$(CONFIG_ENCLOSURE_SERVICES) += enclosure.o
 obj-$(CONFIG_KGDB_TESTS)	+= kgdbts.o
 obj-$(CONFIG_SGI_XP)		+= sgi-xp/
diff -ruN clean/drivers/tty/serial/Kconfig work/drivers/tty/serial/Kconfig
--- clean/drivers/tty/serial/Kconfig	2026-03-10 21:13:40.000000000 +0000
+++ work/drivers/tty/serial/Kconfig	2026-03-10 21:16:07.000000000 +0000
@@ -784,6 +784,16 @@
 	  your boot loader (lilo or loadlin) about how to pass options to the
 	  kernel at boot time.)
 
+config SERIAL_SGI_L1_CONSOLE
+	bool "SGI Altix L1 serial console support"
+	depends on IA64_GENERIC || IA64_SGI_SN2
+	select SERIAL_CORE
+	select SERIAL_CORE_CONSOLE
+	help
+		If you have an SGI Altix and you would like to use the system
+		controller serial port as your console (you want this!),
+		say Y.  Otherwise, say N.
+
 config SERIAL_PIC32
 	tristate "Microchip PIC32 serial support"
 	depends on MACH_PIC32 || (MIPS && COMPILE_TEST)
@@ -885,6 +895,15 @@
 	  To compile this driver as a module, choose M here: the
 	  module will be called jsm.
 
+config SERIAL_SGI_IOC4
+	tristate "SGI IOC4 controller serial support"
+	depends on (IA64_GENERIC || IA64_SGI_SN2) && SGI_IOC4
+	select SERIAL_CORE
+	help
+		If you have an SGI Altix with an IOC4 based Base IO card
+		and wish to use the serial ports on this card, say Y.
+		Otherwise, say N.
+
 config SERIAL_MSM
 	tristate "MSM on-chip serial port support"
 	depends on ARCH_QCOM || COMPILE_TEST
diff -ruN clean/drivers/tty/serial/Makefile work/drivers/tty/serial/Makefile
--- clean/drivers/tty/serial/Makefile	2026-03-10 21:13:40.000000000 +0000
+++ work/drivers/tty/serial/Makefile	2026-03-10 21:16:35.000000000 +0000
@@ -41,6 +41,7 @@
 obj-$(CONFIG_SERIAL_DZ) += dz.o
 obj-$(CONFIG_SERIAL_ZS) += zs.o
 obj-$(CONFIG_SERIAL_SH_SCI) += sh-sci.o
+obj-$(CONFIG_SERIAL_SGI_L1_CONSOLE) += sn_console.o
 obj-$(CONFIG_SERIAL_CPM) += cpm_uart.o
 obj-$(CONFIG_SERIAL_IMX) += imx.o
 obj-$(CONFIG_SERIAL_IMX_EARLYCON) += imx_earlycon.o
@@ -52,6 +53,7 @@
 obj-$(CONFIG_SERIAL_SC16IS7XX_CORE) += sc16is7xx.o
 obj-$(CONFIG_SERIAL_JSM) += jsm/
 obj-$(CONFIG_SERIAL_TXX9) += serial_txx9.o
+obj-$(CONFIG_SERIAL_SGI_IOC4) += ioc4_serial.o
 obj-$(CONFIG_SERIAL_ATMEL) += atmel_serial.o
 obj-$(CONFIG_SERIAL_UARTLITE) += uartlite.o
 obj-$(CONFIG_SERIAL_MSM) += msm_serial.o
diff -ruN clean/include/linux/pci_ids.h work/include/linux/pci_ids.h
--- clean/include/linux/pci_ids.h	2026-03-10 21:13:41.000000000 +0000
+++ work/include/linux/pci_ids.h	2026-03-10 21:16:07.000000000 +0000
@@ -1104,6 +1104,7 @@
 #define PCI_VENDOR_ID_SGI		0x10a9
 #define PCI_DEVICE_ID_SGI_IOC3		0x0003
 #define PCI_DEVICE_ID_SGI_LITHIUM	0x1002
+#define PCI_DEVICE_ID_SGI_IOC4		0x100a
 
 #define PCI_VENDOR_ID_WINBOND		0x10ad
 #define PCI_DEVICE_ID_WINBOND_82C105	0x0105
