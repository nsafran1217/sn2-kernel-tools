+#include <asm/machvec.h>
 #include "tio.h"
 #include "xtalk/xwidgetdev.h"
 #include "xtalk/hubdev.h"
diff --git a/drivers/char/mbcs.c b/drivers/char/mbcs.c
index 0a31b60..a18788b 100644
--- a/drivers/char/mbcs.c
+++ b/drivers/char/mbcs.c
@@ -33,6 +33,7 @@
