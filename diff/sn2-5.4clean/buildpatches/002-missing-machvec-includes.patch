 #define MBCS_DEBUG 0
diff --git a/drivers/char/mspec.c b/drivers/char/mspec.c
index e75c9df..592bfa1 100644
--- a/drivers/char/mspec.c
+++ b/drivers/char/mspec.c
@@ -53,6 +53,7 @@
 #include <asm/sn/io.h>
 #include <asm/sn/bte.h>
 #include <asm/sn/shubio.h>
