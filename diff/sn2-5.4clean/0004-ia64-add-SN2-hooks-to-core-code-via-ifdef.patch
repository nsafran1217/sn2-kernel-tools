 arch/ia64/kernel/acpi.c           | 10 +++---
 arch/ia64/kernel/irq_ia64.c       |  8 ++++-
 arch/ia64/kernel/msi_ia64.c       | 14 ++++++++
 arch/ia64/kernel/sal.c            |  8 +++++
 arch/ia64/kernel/setup.c          | 39 ++++++++++++++++++++---
 arch/ia64/kernel/smpboot.c        |  8 +++++
 arch/ia64/kernel/uncached.c       |  8 +++++
