From: SN2 Port <sn2@port>
Date: Tue, 10 Mar 2026 00:00:00 +0000
Subject: [PATCH] serial: ioc4_serial: fix build errors for 6.1

Fix three build errors in drivers/tty/serial/ioc4_serial.c:

1. pci_alloc_consistent / pci_free_consistent removed (commit
   4167b2b68b69, "PCI: Remove pci_alloc_consistent/pci_free_consistent
   wrappers", v5.18):
   Replace with dma_alloc_coherent / dma_free_coherent which are the
   underlying functions these wrappers called. The first arg changes
   from pci_dev* to &pci_dev->dev, and dma_alloc_coherent takes a
   GFP flags argument.

2. struct uart_port 'timeout' member removed (commit deae1069743e,
   "serial: Remove uart_port::timeout", v6.1):
   The serial core now manages port timeout internally. Remove the
   two lines that computed the_port->timeout.

3. Unused 'state' variable in ioc4_change_speed():
   With the timeout lines removed, state is no longer referenced.
   Remove it to fix -Wunused-variable.

Signed-off-by: SN2 Port <sn2@port>
---
 drivers/tty/serial/ioc4_serial.c | 10 +++-------
 1 file changed, 3 insertions(+), 7 deletions(-)

--- a/drivers/tty/serial/ioc4_serial.c
+++ b/drivers/tty/serial/ioc4_serial.c
@@ -1145,9 +1145,10 @@
 
 		} else {
 			if (port->ip_dma_ringbuf == 0) {
-				port->ip_cpu_ringbuf = pci_alloc_consistent
-					(pdev, TOTAL_RING_BUF_SIZE,
-					&port->ip_dma_ringbuf);
+				port->ip_cpu_ringbuf = dma_alloc_coherent
+					(&pdev->dev, TOTAL_RING_BUF_SIZE,
+					&port->ip_dma_ringbuf,
+					GFP_KERNEL);
 
 			}
 			BUG_ON(!((((int64_t)port->ip_dma_ringbuf) &
@@ -1690,7 +1691,6 @@
 	int baud, bits;
 	unsigned cflag, iflag;
 	int new_parity = 0, new_parity_enable = 0, new_stop = 0, new_data = 8;
-	struct uart_state *state = the_port->state;
 
 	cflag = new_termios->c_cflag;
 	iflag = new_termios->c_iflag;
@@ -1738,8 +1738,6 @@
 
 	if (!the_port->fifosize)
 		the_port->fifosize = IOC4_FIFO_CHARS;
-	the_port->timeout = ((the_port->fifosize * HZ * bits) / (baud / 10));
-	the_port->timeout += HZ / 50;	/* Add .02 seconds of slop */
 
 	the_port->ignore_status_mask = N_ALL_INPUT;
 
@@ -2672,7 +2670,7 @@
 		port = control->ic_port[port_num].icp_port;
 		/* we allocate in pairs */
 		if (!(port_num & 1) && port) {
-			pci_free_consistent(port->ip_pdev,
+			dma_free_coherent(&port->ip_pdev->dev,
 					TOTAL_RING_BUF_SIZE,
 					port->ip_cpu_ringbuf,
 					port->ip_dma_ringbuf);
