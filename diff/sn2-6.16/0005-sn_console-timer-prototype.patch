Subject: [PATCH 0005] serial/sn_console: from_timer rename + missing prototype

1. from_timer() was renamed to timer_container_of() in 6.12.
   Update sn_sal_timer_poll().

2. sn_serial_console_early_setup() is called from setup.c via
   a block-scoped extern but had no prototype visible in
   sn_console.c.  Add forward declaration.

---
 drivers/tty/serial/sn_console.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

--- a/drivers/tty/serial/sn_console.c	2026-03-14 16:34:26.000000000 +0000
+++ b/drivers/tty/serial/sn_console.c	2026-03-14 17:36:03.094728905 +0000
@@ -112,6 +112,9 @@
 static int snt_intr_input_pending(void);
 static void sn_transmit_chars(struct sn_cons_port *, int);
 
+/* Called from arch/ia64/kernel/setup.c */
+int __init sn_serial_console_early_setup(void);
+
 /* A table for polling:
  */
 static struct sn_sal_ops poll_ops = {
@@ -608,7 +611,7 @@
  */
 static void sn_sal_timer_poll(struct timer_list *t)
 {
-	struct sn_cons_port *port = from_timer(port, t, sc_timer);
+	struct sn_cons_port *port = timer_container_of(port, t, sc_timer);
 	unsigned long flags;
 
 	if (!port)
