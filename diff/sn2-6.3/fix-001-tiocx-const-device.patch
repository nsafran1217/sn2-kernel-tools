Subject: [PATCH] ia64/sn2: fix tiocx_uevent signature for 6.3 const device API

Linux 6.3 changed the bus_type .uevent callback signature from
  int (*uevent)(struct device *dev, struct kobj_uevent_env *env)
to
  int (*uevent)(const struct device *dev, struct kobj_uevent_env *env)

(commit 5e33dc6 "driver core: make uevent callback const")

Update tiocx_uevent() to use const struct device * to match.

--- a/arch/ia64/sn/kernel/tiocx.c
+++ b/arch/ia64/sn/kernel/tiocx.c
@@ -66,7 +66,7 @@
 
 }
 
-static int tiocx_uevent(struct device *dev, struct kobj_uevent_env *env)
+static int tiocx_uevent(const struct device *dev, struct kobj_uevent_env *env)
 {
 	return -ENODEV;
 }
